{"input": "Create TCP socket", "output": ".sock: TCP"}
{"input": "Bind socket to port 8080", "output": ".sock: TCP\n.addr: ALC 16\n.a0: PUT .addr 0 2\n.a1: PUT .addr 2 31\n.a2: PUT .addr 3 144\n.bind: BND .sock .addr"}
{"input": "Listen for connections with backlog 10", "output": ".listen: LST .sock 10"}
{"input": "Accept incoming connection", "output": ".client: ACC .sock"}
