{"input": "Receive data from client", "output": ".buf: ALC 1024\n.n: RCV .client .buf 1024"}
{"input": "Close socket connection", "output": ".close: CLS .client"}
{"input": "Create simple TCP server on port 8080", "output": ".sock: TCP\n.addr: ALC 16\n.a0: PUT .addr 0 2\n.a1: PUT .addr 2 31\n.a2: PUT .addr 3 144\n.bind: BND .sock .addr\n.listen: LST .sock 10\n.client: ACC .sock\n.buf: ALC 512\n.n: RCV .client .buf 512\n.send: XMT .client .buf .n\n.close: CLS .client"}
{"input": "TCP echo server with loop", "output": ".sock: TCP\n.addr: ALC 16\n.a0: PUT .addr 0 2\n.a1: PUT .addr 2 31\n.a2: PUT .addr 3 144\n.bind: BND .sock .addr\n.listen: LST .sock 10\n.loop: ACC .sock\n.buf: ALC 512\n.n: RCV .loop .buf 512\n.send: XMT .loop .buf .n\n.cls: CLS .loop\n.loop >> .loop"}
