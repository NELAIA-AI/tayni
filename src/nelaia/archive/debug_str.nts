.path: "input.nts"
.zero: 0
.handle: FOP .path .zero
.srcbuf: ALC 512
.slen: FRD .handle .srcbuf 512
.closed: FCL .handle

.tokens: FSM .srcbuf .slen
.tcnt: GET .tokens 0

.t3_off: ADD .tokens 20
.t3_start: GET .t3_off 1
.t3_len: GET .t3_off 2

.out: ALC 64
.r1: PUT .out 0 .tcnt
.r2: PUT .out 8 .t3_start
.r3: PUT .out 16 .t3_len
.r4: PUT .out 24 .slen
.p: PRT .out 32
