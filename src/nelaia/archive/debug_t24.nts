.zero: 0
.bufsize: 256

.path: "test_input.nts"
.handle: FOP .path .zero
.srcbuf: ALC .bufsize
.slen: FRD .handle .srcbuf .bufsize
.closed: FCL .handle

.tokens: FSM .srcbuf .slen

-- Token at offset 24
.t: ADD .tokens 24
.t_type: GET .t 0
.t_start: GET .t 1
.t_len: GET .t 2

-- Print char at t_start
.ch: CHR .srcbuf .t_start
.out: ALC 16
.p0: PUT .out 0 .ch
.p1: PRT .out 1

.result: ADD .t_start .zero
