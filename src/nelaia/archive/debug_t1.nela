-- Debug: check what token 1 (offset 4) contains for single line
.zero: 0
.bufsize: 256

.path: "test_input.nela"
.handle: FOP .path .zero
.srcbuf: ALC .bufsize
.slen: FRD .handle .srcbuf .bufsize
.closed: FCL .handle

.tokens: FSM .srcbuf .slen

-- Token at offset 4
.t1: ADD .tokens 4
.t1_type: GET .t1 0
.t1_start: GET .t1 1
.t1_len: GET .t1 2

-- Print char at t1_start
.ch: CHR .srcbuf .t1_start
.out: ALC 16
.p0: PUT .out 0 .ch
.p1: PRT .out 1

.result: ADD .t1_start .zero
