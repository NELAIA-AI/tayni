.path: "input.nela"
.zero: 0
.handle: FOP .path .zero
.srcbuf: ALC 64

-- Manual ReadFile call to check return value
.h_ptr: ADD .handle 0
.buf_ptr: ADD .srcbuf 0

-- Read and check
.slen: FRD .handle .srcbuf 64
.closed: FCL .handle

-- Print buffer content
.c0: CHR .srcbuf 0
.c1: CHR .srcbuf 1
.c2: CHR .srcbuf 2

.out: ALC 64
.r0: PUT .out 0 .slen
.r1: PUT .out 8 .c0
.r2: PUT .out 16 .c1
.r3: PUT .out 24 .c2
.p: PRT .out 32
