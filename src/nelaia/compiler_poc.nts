.w25: PUT .out 25 .c25
.c26: CHR .hdr 26
.w26: PUT .out 26 .c26
.c27: CHR .hdr 27
.w27: PUT .out 27 .c27
.c28: CHR .hdr 28
.w28: PUT .out 28 .c28
.c29: CHR .hdr 29
.w29: PUT .out 29 .c29
.c30: CHR .hdr 30
.w30: PUT .out 30 .c30

-- Insert variable name (from parsed token)
.wn: PUT .out 31 .name_ch

-- " = add i64 " (11 chars) at pos 32
.mid: " = add i64 "
.m0: CHR .mid 0
.wm0: PUT .out 32 .m0
.m1: CHR .mid 1
.wm1: PUT .out 33 .m1
.m2: CHR .mid 2
.wm2: PUT .out 34 .m2
.m3: CHR .mid 3
.wm3: PUT .out 35 .m3
.m4: CHR .mid 4
