.m9: CHR .mid 9
.wm9: PUT .out 41 .m9
.m10: CHR .mid 10
.wm10: PUT .out 42 .m10

-- Insert value (from parsed token)
.wv: PUT .out 43 .val_ch

-- ", 0\n  ret i64 %"  (15 chars) at pos 44
.mid2: ", 0\n  ret i64 %"
.n0: CHR .mid2 0
.wn0: PUT .out 44 .n0
.n1: CHR .mid2 1
.wn1: PUT .out 45 .n1
.n2: CHR .mid2 2
.wn2: PUT .out 46 .n2
.n3: CHR .mid2 3
.wn3: PUT .out 47 .n3
.n4: CHR .mid2 4
