.w20: PUT .out 20 .c20
.c21: CHR .hdr 21
.w21: PUT .out 21 .c21
.c22: CHR .hdr 22
.w22: PUT .out 22 .c22
.c23: CHR .hdr 23
.w23: PUT .out 23 .c23
