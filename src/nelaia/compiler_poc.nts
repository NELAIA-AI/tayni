-- NELAIA Self-Hosted Compiler PoC v0.1
-- Full pipeline: source -> tokens -> nodes -> LLVM IR
-- Compiles: .x: 5

.zero: 0

-- Source code
.src: ".x: 5"
.slen: 5

-- Step 1: Tokenize
.tokens: FSM .src .slen
.tptr: ADD .tokens .zero

-- Step 2: Parse - extract node info
-- Token 1 (ID "x") at offset 12
.t1: ADD .tptr 12
.t1_st: GET .t1 1

-- Token 3 (NUM "5") at offset 20
.t3: ADD .tptr 20
.t3_st: GET .t3 1

-- Get actual chars
.name_ch: CHR .src .t1_st
.val_ch: CHR .src .t3_st

-- Step 3: Emit LLVM IR
.out: ALC 256

-- "define i64 @main() {\nentry:\n  %" (31 chars)
.hdr: "define i64 @main() {\nentry:\n  %"
.i: 0
.c0: CHR .hdr 0
.w0: PUT .out 0 .c0
