.n14: CHR .mid2 14
.wn14: PUT .out 58 .n14

-- Insert return var name
.wr: PUT .out 59 .name_ch

-- "\n}\n" (3 chars) at pos 60
.ftr: "\n}\n"
.f0: CHR .ftr 0
.wf0: PUT .out 60 .f0
.f1: CHR .ftr 1
.wf1: PUT .out 61 .f1
.f2: CHR .ftr 2
.wf2: PUT .out 62 .f2

-- Output
.title: "=== NELAIA Self-Hosted Compiler PoC ===\n\n"
.ot: PRT .title 41

.src_msg: "Source: "
.os: PRT .src_msg 8
.osc: PRT .src .slen
.nl: "\n\n"
.onl: PRT .nl 2

.ir_msg: "Generated LLVM IR:\n"
.oir: PRT .ir_msg 19
.oout: PRT .out 63

.done: "\nCompilation successful!\n"
.od: PRT .done 25

.result: ADD .ot .os .osc .onl .oir .oout .od
