.i8: PUT .exe 520 141
.i9: PUT .exe 521 13
-- disp = 0x3000 - (0x1007 + 7) = 0x3000 - 0x100E = 0x1FF2
.i10: PUT .exe 522 242
.i11: PUT .exe 523 31
.i12: PUT .exe 524 0
.i13: PUT .exe 525 0

