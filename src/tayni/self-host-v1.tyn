-- ===== ESCRIBIR PE =====
.opath: "self1.exe"
.oh: FOP .opath .one
.wlen: FWR .oh .exe .slen
.oc: FCL .oh

-- ===== OUTPUT =====
.hdr: "Self-Hosting v1: self1.exe\n"
.p0: PRT .hdr 27

.f1: FRE .exe

!
