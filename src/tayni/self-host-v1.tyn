-- TAYNI Self-Hosting v1.0
-- Genera compiler.exe que lee input.tyn y genera out.exe
-- Basado en asm3.tyn (funciona) + file write
-- Fecha: 2026-06-16

.zero: 0
.one: 1

-- ===== CONSTANTES =====
.CODE_BASE: 512
.RVA_CODE: 4096
.RVA_IAT: 8192
.RVA_DATA: 12288

-- IAT offsets en fileio2.exe.exe
.IAT_GetStdHandle: 0
.IAT_WriteFile: 8
.IAT_ExitProcess: 16
.IAT_VirtualAlloc: 24
.IAT_CreateFileA: 32
.IAT_ReadFile: 40
.IAT_CloseHandle: 48

-- ===== LEER TEMPLATE =====
.exe: ALC 8192
.spath: "fileio2.exe.exe"
.sh: FOP .spath .zero
.slen: FRD .sh .exe 8192
.sc: FCL .sh

-- ===== GENERAR CÓDIGO =====
-- El código generado:
-- 1. Lee input.tyn
-- 2. Parsea el valor
-- 3. Lee mini.exe
-- 4. Modifica byte 513
-- 5. Escribe out.exe
-- 6. Exit con el valor

-- sub rsp, 120 (0x78) - stack frame grande
.i0: PUT .exe 512 72
.i1: PUT .exe 513 129
.i2: PUT .exe 514 236
.i3: PUT .exe 515 120
.i4: PUT .exe 516 0
.i5: PUT .exe 517 0
.i6: PUT .exe 518 0

