-- mov r8d, r14d
.c165: PUT .pe 677 69
.c166: PUT .pe 678 137
.c167: PUT .pe 679 240
-- lea r9, [rsp+56]
.c168: PUT .pe 680 76
.c169: PUT .pe 681 141
.c170: PUT .pe 682 76
.c171: PUT .pe 683 36
.c172: PUT .pe 684 56
-- mov qword [rsp+32], 0
.c173: PUT .pe 685 72
.c174: PUT .pe 686 199
.c175: PUT .pe 687 68
.c176: PUT .pe 688 36
.c177: PUT .pe 689 32
.c178: PUT .pe 690 0
