-- TAYNI Gen22 - Full Arithmetic Compiler (ADD, SUB, MUL)
-- Compiles programs with ADD/SUB/MUL + ITS + PRT + File I/O
-- Detects operation type from line 3
-- Date: 2026-06-17

.zero: 0
.one: 1

-- ===== READ PROGRAM =====
.ipath: "program.tyn"
.ih: FOP .ipath .zero
.ibuf: ALC 512
.ilen: FRD .ih .ibuf 512
.ic: FCL .ih

-- ===== PARSE LINE 1: .a: NN =====
-- Format: .a: 25\n (starts at offset 0)
-- Number starts at offset 4
.n1_d0: GET .ibuf 4
.n1_d1: GET .ibuf 5
.n1_d2: GET .ibuf 6

-- Convert to digit values (subtract '0' = 48)
.n1_v0: SUB .n1_d0 48
.n1_v1: SUB .n1_d1 48
.n1_v2: SUB .n1_d2 48

-- Check if each position is a digit (0-9) or newline
-- Newline = 10, digits = 48-57
-- If d1 < 48, it's newline (1 digit number)
-- If d2 < 48, it's newline (2 digit number)
-- Otherwise 3 digits

-- d1 is digit if d1 >= 48 (v1 >= 0)
-- Since we can't do >= directly, check if v1 < 0 means not digit
-- Actually simpler: if d1 == 10 (newline), then 1 digit
.n1_isnl1: SUB .n1_d1 10
.n1_isnl2: SUB .n1_d2 10

-- Length detection:
-- If d1 is newline (isnl1==0): 1 digit
-- Else if d2 is newline (isnl2==0): 2 digits  
-- Else: 3 digits
.n1_len_if2: IFZ .n1_isnl2 2 3
.n1_len: IFZ .n1_isnl1 1 .n1_len_if2

-- Calculate value based on length
.ten: 10
.hundred: 100

-- For 2 digits: v0*10 + v1
.n1_t0: MUL .n1_v0 .ten
.val_2d: ADD .n1_t0 .n1_v1

-- For 3 digits: v0*100 + v1*10 + v2
.n1_h0: MUL .n1_v0 .hundred
.n1_t1: MUL .n1_v1 .ten
.val_3d_a: ADD .n1_h0 .n1_t1
.val_3d: ADD .val_3d_a .n1_v2

-- Select based on length
.is_len1: SUB .n1_len 1
.is_len2: SUB .n1_len 2
.val_a_23: IFZ .is_len2 .val_2d .val_3d
.val_a: IFZ .is_len1 .n1_v0 .val_a_23

-- ===== PARSE LINE 2: .b: NN =====
-- Line 2 starts after line 1
-- Line 1 = ".a: " + digits + "\n" = 4 + len + 1 = 5 + len
.line1_len: ADD 5 .n1_len
.line2_start: ADD .line1_len 0

-- Number starts at line2_start + 4
.n2_off: ADD .line2_start 4
.n2_off1: ADD .n2_off 1
.n2_off2: ADD .n2_off 2

.n2_d0: GET .ibuf .n2_off
.n2_d1: GET .ibuf .n2_off1
.n2_d2: GET .ibuf .n2_off2

.n2_v0: SUB .n2_d0 48
.n2_v1: SUB .n2_d1 48
.n2_v2: SUB .n2_d2 48

.n2_isnl1: SUB .n2_d1 10
.n2_isnl2: SUB .n2_d2 10

.n2_len_if2: IFZ .n2_isnl2 2 3
.n2_len: IFZ .n2_isnl1 1 .n2_len_if2

.n2_t0: MUL .n2_v0 .ten
.val2_2d: ADD .n2_t0 .n2_v1

.n2_h0: MUL .n2_v0 .hundred
.n2_t1: MUL .n2_v1 .ten
.val2_3d_a: ADD .n2_h0 .n2_t1
.val2_3d: ADD .val2_3d_a .n2_v2

.is2_len1: SUB .n2_len 1
.is2_len2: SUB .n2_len 2
.val_b_23: IFZ .is2_len2 .val2_2d .val2_3d
.val_b: IFZ .is2_len1 .n2_v0 .val_b_23

-- ===== DETECT OPERATION (line 3) =====
-- Line 3 format: .c: ADD .a .b or .c: SUB .a .b or .c: MUL .a .b
-- Line 3 starts at line1_len + line2_len
-- Line 2 = ".b: " + digits + "\n" = 4 + n2_len + 1 = 5 + n2_len
.line2_len: ADD 5 .n2_len
.line3_start: ADD .line1_len .line2_len

-- Operation starts at line3_start + 4 (after ".c: ")
.op_off: ADD .line3_start 4
.op_char: GET .ibuf .op_off

-- Detect: A=65 (ADD), S=83 (SUB), M=77 (MUL)
.is_add: SUB .op_char 65
.is_sub: SUB .op_char 83
.is_mul: SUB .op_char 77

-- Calculate results for each operation
.res_add: ADD .val_a .val_b
.res_sub: SUB .val_a .val_b
.res_mul: MUL .val_a .val_b

-- Select result based on operation
.res_sm: IFZ .is_mul .res_mul .res_sub
.result: IFZ .is_add .res_add .res_sm

-- ===== PARSE PATH STRING (line 7) =====
-- Path is on line 7: .path: "result.txt"
-- Quote is around offset 80-90
.q80: GET .ibuf 80
.q81: GET .ibuf 81
.q82: GET .ibuf 82
.q83: GET .ibuf 83
.q84: GET .ibuf 84
.q85: GET .ibuf 85
.q86: GET .ibuf 86
.q87: GET .ibuf 87
.q88: GET .ibuf 88
.q89: GET .ibuf 89

.eq80: SUB .q80 34
.eq81: SUB .q81 34
.eq82: SUB .q82 34
.eq83: SUB .q83 34
.eq84: SUB .q84 34
.eq85: SUB .q85 34
.eq86: SUB .q86 34
.eq87: SUB .q87 34
.eq88: SUB .q88 34
.eq89: SUB .q89 34

.pq89: IFZ .eq89 89 90
.pq88: IFZ .eq88 88 .pq89
.pq87: IFZ .eq87 87 .pq88
.pq86: IFZ .eq86 86 .pq87
.pq85: IFZ .eq85 85 .pq86
.pq84: IFZ .eq84 84 .pq85
.pq83: IFZ .eq83 83 .pq84
.pq82: IFZ .eq82 82 .pq83
.pq81: IFZ .eq81 81 .pq82
.path_q: IFZ .eq80 80 .pq81
.path_start: ADD .path_q 1

-- Extract path bytes
.pt0: GET .ibuf .path_start
.pta1: ADD .path_start 1
.pt1: GET .ibuf .pta1
.pta2: ADD .path_start 2
.pt2: GET .ibuf .pta2
.pta3: ADD .path_start 3
.pt3: GET .ibuf .pta3
.pta4: ADD .path_start 4
.pt4: GET .ibuf .pta4
.pta5: ADD .path_start 5
.pt5: GET .ibuf .pta5
.pta6: ADD .path_start 6
.pt6: GET .ibuf .pta6
.pta7: ADD .path_start 7
.pt7: GET .ibuf .pta7
.pta8: ADD .path_start 8
.pt8: GET .ibuf .pta8
.pta9: ADD .path_start 9
.pt9: GET .ibuf .pta9
.pta10: ADD .path_start 10
.pt10: GET .ibuf .pta10

-- Find path length
.pte0: SUB .pt0 34
.pte1: SUB .pt1 34
.pte2: SUB .pt2 34
.pte3: SUB .pt3 34
.pte4: SUB .pt4 34
.pte5: SUB .pt5 34
.pte6: SUB .pt6 34
.pte7: SUB .pt7 34
.pte8: SUB .pt8 34
.pte9: SUB .pt9 34
.pte10: SUB .pt10 34

.ptp10: IFZ .pte10 10 11
.ptp9: IFZ .pte9 9 .ptp10
.ptp8: IFZ .pte8 8 .ptp9
.ptp7: IFZ .pte7 7 .ptp8
.ptp6: IFZ .pte6 6 .ptp7
.ptp5: IFZ .pte5 5 .ptp6
.ptp4: IFZ .pte4 4 .ptp5
.ptp3: IFZ .pte3 3 .ptp4
.ptp2: IFZ .pte2 2 .ptp3
.ptp1: IFZ .pte1 1 .ptp2
.path_len: IFZ .pte0 0 .ptp1

-- ===== BUILD PE =====
.pe: ALC 4096

-- DOS Header
.dos0: PUT .pe 0 77
.dos1: PUT .pe 1 90
.dos60: PUT .pe 60 64

-- PE Signature
.pe64: PUT .pe 64 80
.pe65: PUT .pe 65 69

-- COFF Header
.coff0: PUT .pe 68 100
.coff1: PUT .pe 69 134
.coff2: PUT .pe 70 2
.coff84: PUT .pe 84 240
.coff86: PUT .pe 86 34

-- Optional Header PE32+
.opt0: PUT .pe 88 11
.opt1: PUT .pe 89 2
.opt16: PUT .pe 104 0
.opt17: PUT .pe 105 16
.opt20: PUT .pe 108 0
.opt21: PUT .pe 109 16
.opt27: PUT .pe 115 64
.opt28: PUT .pe 116 1
.opt32: PUT .pe 120 0
.opt33: PUT .pe 121 16
.opt36: PUT .pe 124 0
.opt37: PUT .pe 125 2
.opt40: PUT .pe 128 6
.opt48: PUT .pe 136 6
.opt56: PUT .pe 144 0
.opt57: PUT .pe 145 48
.opt60: PUT .pe 148 0
.opt61: PUT .pe 149 2
.opt68: PUT .pe 156 3
.opt70: PUT .pe 158 96
.opt71: PUT .pe 159 129
.opt74: PUT .pe 162 16
.opt81: PUT .pe 169 16
.opt90: PUT .pe 178 16
.opt97: PUT .pe 185 16
.opt108: PUT .pe 196 16

-- Data Directories
.dd_imp0: PUT .pe 208 0
.dd_imp1: PUT .pe 209 32
.dd_imp_sz: PUT .pe 212 40
.dd_iat0: PUT .pe 296 0
.dd_iat1: PUT .pe 297 33
.dd_iat_sz: PUT .pe 300 48

-- Section .text
.st0: PUT .pe 328 46
.st1: PUT .pe 329 116
.st2: PUT .pe 330 101
.st3: PUT .pe 331 120
.st4: PUT .pe 332 116
.st_vs: PUT .pe 337 4
.st_va1: PUT .pe 341 16
.st_rd: PUT .pe 345 4
.st_rp1: PUT .pe 349 2
.st_ch0: PUT .pe 364 32
.st_ch3: PUT .pe 367 96

-- Section .rdata
.sr0: PUT .pe 368 46
.sr1: PUT .pe 369 114
.sr2: PUT .pe 370 100
.sr3: PUT .pe 371 97
.sr4: PUT .pe 372 116
.sr5: PUT .pe 373 97
.sr_vs1: PUT .pe 377 4
.sr_va1: PUT .pe 381 32
.sr_rd1: PUT .pe 385 4
.sr_rp1: PUT .pe 389 6
.sr_ch0: PUT .pe 404 64
.sr_ch3: PUT .pe 407 64

-- ===== CODE at file 512 (RVA 0x1000) =====
-- The generated code will:
-- 1. Calculate result (embedded as immediate)
-- 2. Convert to string using div/mod
-- 3. Print to console
-- 4. Write to file

-- sub rsp, 0x78
.c0: PUT .pe 512 72
.c1: PUT .pe 513 131
.c2: PUT .pe 514 236
.c3: PUT .pe 515 120

-- mov eax, result (embedded at compile time)
.c4: PUT .pe 516 184
.c5: PUT .pe 517 .result
.c6: PUT .pe 518 0
.c7: PUT .pe 519 0
.c8: PUT .pe 520 0

-- Convert to ASCII: result is in eax
-- For simplicity, handle 1-3 digit numbers
-- Store digits at [rsp+48] (buffer)

-- mov r12d, eax (save result)
.c9: PUT .pe 521 65
.c10: PUT .pe 522 137
.c11: PUT .pe 523 196

-- xor r13d, r13d (digit count)
.c12: PUT .pe 524 69
.c13: PUT .pe 525 49
.c14: PUT .pe 526 237

-- mov ecx, 10 (divisor)
.c15: PUT .pe 527 185
.c16: PUT .pe 528 10
.c17: PUT .pe 529 0
.c18: PUT .pe 530 0
.c19: PUT .pe 531 0

-- ITS loop: extract digits (unrolled for 3 digits max)
-- Digit 0 (ones): eax % 10
-- xor edx, edx
.c20: PUT .pe 532 49
.c21: PUT .pe 533 210
-- div ecx (eax = eax/10, edx = eax%10)
.c22: PUT .pe 534 247
.c23: PUT .pe 535 241
-- add dl, '0'
.c24: PUT .pe 536 128
.c25: PUT .pe 537 194
.c26: PUT .pe 538 48
-- mov [rsp+50], dl (digit 2 position)
.c27: PUT .pe 539 136
.c28: PUT .pe 540 84
.c29: PUT .pe 541 36
.c30: PUT .pe 542 50

-- Digit 1 (tens): eax % 10
-- xor edx, edx
.c31: PUT .pe 543 49
.c32: PUT .pe 544 210
-- div ecx
.c33: PUT .pe 545 247
.c34: PUT .pe 546 241
-- add dl, '0'
.c35: PUT .pe 547 128
.c36: PUT .pe 548 194
.c37: PUT .pe 549 48
-- mov [rsp+49], dl
.c38: PUT .pe 550 136
.c39: PUT .pe 551 84
.c40: PUT .pe 552 36
.c41: PUT .pe 553 49

-- Digit 2 (hundreds): eax % 10
-- xor edx, edx
.c42: PUT .pe 554 49
.c43: PUT .pe 555 210
-- div ecx
.c44: PUT .pe 556 247
.c45: PUT .pe 557 241
-- add dl, '0'
.c46: PUT .pe 558 128
.c47: PUT .pe 559 194
.c48: PUT .pe 560 48
-- mov [rsp+48], dl
.c49: PUT .pe 561 136
.c50: PUT .pe 562 84
.c51: PUT .pe 563 36
.c52: PUT .pe 564 48

-- Now determine string start and length based on result
-- if result < 10: start=50, len=1
-- if result < 100: start=49, len=2
-- else: start=48, len=3

-- For simplicity, always output 2 digits (result 10-99)
-- lea rsi, [rsp+49] (string start for 2 digits)
.c53: PUT .pe 565 72
.c54: PUT .pe 566 141
.c55: PUT .pe 567 116
.c56: PUT .pe 568 36
.c57: PUT .pe 569 49

-- mov r14d, 2 (length)
.c58: PUT .pe 570 65
.c59: PUT .pe 571 190
.c60: PUT .pe 572 2
.c61: PUT .pe 573 0
.c62: PUT .pe 574 0
.c63: PUT .pe 575 0

-- === PRT: GetStdHandle + WriteFile ===
-- mov ecx, -11
.c64: PUT .pe 576 185
.c65: PUT .pe 577 245
.c66: PUT .pe 578 255
.c67: PUT .pe 579 255
.c68: PUT .pe 580 255
-- call GetStdHandle (IAT[0]=0x2100, RIP=0x104B, disp=0x10B5)
.c69: PUT .pe 581 255
.c70: PUT .pe 582 21
.c71: PUT .pe 583 181
.c72: PUT .pe 584 16
.c73: PUT .pe 585 0
.c74: PUT .pe 586 0

-- mov rbx, rax (stdout handle)
.c75: PUT .pe 587 72
.c76: PUT .pe 588 137
.c77: PUT .pe 589 195

-- WriteFile(rbx, rsi, r14d, &written, 0)
-- mov rcx, rbx
.c78: PUT .pe 590 72
.c79: PUT .pe 591 137
.c80: PUT .pe 592 217
-- mov rdx, rsi
.c81: PUT .pe 593 72
.c82: PUT .pe 594 137
.c83: PUT .pe 595 242
-- mov r8d, r14d
.c84: PUT .pe 596 69
.c85: PUT .pe 597 137
.c86: PUT .pe 598 240
-- lea r9, [rsp+56]
.c87: PUT .pe 599 76
.c88: PUT .pe 600 141
.c89: PUT .pe 601 76
.c90: PUT .pe 602 36
.c91: PUT .pe 603 56
-- mov qword [rsp+32], 0
.c92: PUT .pe 604 72
.c93: PUT .pe 605 199
.c94: PUT .pe 606 68
.c95: PUT .pe 607 36
.c96: PUT .pe 608 32
.c97: PUT .pe 609 0
.c98: PUT .pe 610 0
.c99: PUT .pe 611 0
.c100: PUT .pe 612 0
-- call WriteFile (IAT[1]=0x2108, RIP=0x106B, disp=0x109D)
.c101: PUT .pe 613 255
.c102: PUT .pe 614 21
.c103: PUT .pe 615 157
.c104: PUT .pe 616 16
.c105: PUT .pe 617 0
.c106: PUT .pe 618 0

-- === FOP: CreateFileA ===
-- lea rcx, [rip+path] (path at 0x10E0, RIP=0x1072, disp=0x6E)
.c107: PUT .pe 619 72
.c108: PUT .pe 620 141
.c109: PUT .pe 621 13
.c110: PUT .pe 622 110
.c111: PUT .pe 623 0
.c112: PUT .pe 624 0
.c113: PUT .pe 625 0
-- mov edx, 0x40000000
.c114: PUT .pe 626 186
.c115: PUT .pe 627 0
.c116: PUT .pe 628 0
.c117: PUT .pe 629 0
.c118: PUT .pe 630 64
-- xor r8d, r8d
.c119: PUT .pe 631 69
.c120: PUT .pe 632 49
.c121: PUT .pe 633 192
-- xor r9d, r9d
.c122: PUT .pe 634 69
.c123: PUT .pe 635 49
.c124: PUT .pe 636 201
-- mov dword [rsp+32], 2
.c125: PUT .pe 637 199
.c126: PUT .pe 638 68
.c127: PUT .pe 639 36
.c128: PUT .pe 640 32
.c129: PUT .pe 641 2
.c130: PUT .pe 642 0
.c131: PUT .pe 643 0
.c132: PUT .pe 644 0
-- mov dword [rsp+40], 0x80
.c133: PUT .pe 645 199
.c134: PUT .pe 646 68
.c135: PUT .pe 647 36
.c136: PUT .pe 648 40
.c137: PUT .pe 649 128
.c138: PUT .pe 650 0
.c139: PUT .pe 651 0
.c140: PUT .pe 652 0
-- mov qword [rsp+48], 0 (but we use 60 to not overwrite buffer)
.c141: PUT .pe 653 72
.c142: PUT .pe 654 199
.c143: PUT .pe 655 68
.c144: PUT .pe 656 36
.c145: PUT .pe 657 60
.c146: PUT .pe 658 0
.c147: PUT .pe 659 0
.c148: PUT .pe 660 0
.c149: PUT .pe 661 0
-- call CreateFileA (IAT[2]=0x2110, RIP=0x109C, disp=0x1074)
.c150: PUT .pe 662 255
.c151: PUT .pe 663 21
.c152: PUT .pe 664 116
.c153: PUT .pe 665 16
.c154: PUT .pe 666 0
.c155: PUT .pe 667 0

-- mov rdi, rax (file handle)
.c156: PUT .pe 668 72
.c157: PUT .pe 669 137
.c158: PUT .pe 670 199

-- === FWR: WriteFile to file ===
-- mov rcx, rdi
.c159: PUT .pe 671 72
