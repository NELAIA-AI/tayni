-- VEC test: push, set, get
.out: ALC 64

-- Create vector
@.v: VEC 16

-- Push 4 values
@.p1: VPH .v 65
@.p2: VPH .v 66
@.p3: VPH .v 67
@.p4: VPH .v 68

-- Set index 1 to 90 (was 66)
@.set: VST .v 1 90

-- Get value at index 1 (should be 90 now)
@.val: VGT .v 1

-- Print as number
@.its: ITS @.val .out
.prt: PRT .out @.its

!
