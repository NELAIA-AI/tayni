-- TAYNI Compiler v1.1 - Simplified test
-- Just read files and print result

.zero: 0
.one: 1
.ten: 10
.digit_0: 48

.src: ALC 512
.symbols: ALC 256
.code: ALC 512
.template: ALC 2048
.out: ALC 64

-- Read source file
.src_path: "simple.tyn"
@.src_h: FOP .src_path 0
@.src_len: FRD @.src_h .src 512

-- Read PE template
.tpl_path: "pe-template.bin"
@.tpl_h: FOP .tpl_path 0
@.tpl_len: FRD @.tpl_h .template 1536

-- Parse Line 0: ".a: 10" - value at pos 4-5
@.ch0_4: GET .src 4
@.ch0_5: GET .src 5
@.d0_0: SUB @.ch0_4 .digit_0
@.d0_1: SUB @.ch0_5 .digit_0
@.t0: MUL @.d0_0 .ten
@.val_a: ADD @.t0 @.d0_1
@.s0: PUT .symbols 0 @.val_a

-- Parse Line 1: ".b: 20" - value at pos 11-12 (LF line ending)
@.ch1_4: GET .src 11
@.ch1_5: GET .src 12
@.d1_0: SUB @.ch1_4 .digit_0
@.d1_1: SUB @.ch1_5 .digit_0
@.t1: MUL @.d1_0 .ten
@.val_b: ADD @.t1 @.d1_1
@.s1: PUT .symbols 8 @.val_b

-- Compute result
@.read_a: GET .symbols 0
@.read_b: GET .symbols 8
@.result: ADD @.read_a @.read_b

-- Print result (should be 30)
@.msg_len: ITS @.result .out
.done: PRT .out @.msg_len

!
