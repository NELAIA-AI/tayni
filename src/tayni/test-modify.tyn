-- Test: Read template, modify it, write output
.buf: ALC 1536
.out: ALC 32

-- Read template
.in_path: "pe-template.bin"
@.in_h: FOP .in_path 0
@.in_len: FRD @.in_h .buf 1536

-- Modify: put code at offset 512
-- Just put a simple "ret" instruction (0xC3)
.m0: PUT .buf 512 195

-- Write to output
.out_path: "modified.exe"
@.out_h: FOP .out_path 1
@.out_len: FWR @.out_h .buf 1536

-- Print bytes written
@.len: ITS @.out_len .out
.done: PRT .out @.len

!
