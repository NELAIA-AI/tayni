-- TAYNI Test Runtime Analysis
-- Force runtime evaluation

.zero: 0

.data: ALC 64
.out: ALC 64

-- Store 42 at offset 0 of data buffer (runtime)
@.store: PUT .data 0 42

-- Read back from offset 0 of data buffer (runtime)
@.read: GET .data 0

-- Add 0 to force runtime (hack)
@.val: ADD @.read .zero

-- Convert to string in out buffer
@.len: ITS @.val .out

-- Print from out buffer
.done: PRT .out @.len

!
