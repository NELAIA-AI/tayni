.hn2_9: PUT .pe 1993 99
.hn2_10: PUT .pe 1994 101
.hn2_11: PUT .pe 1995 115
.hn2_12: PUT .pe 1996 115

-- ===== WRITE OUTPUT =====
.opath: "out.exe"
.oh: FOP .opath .one
.owlen: FWR .oh .pe 2560
.oc: FCL .oh

-- ===== STATUS =====
.hdr: "Gen33: Compiler created out.exe\n"
.ph: PRT .hdr 32
.msg1: "Result: 25+17="
.pm1: PRT .msg1 14
.num: ALC 8
.its1: ITS .result .num
.pn1: PRT .num .its1
.nl: "\n"
.pnl: PRT .nl 1

.f1: FRE .pe
.f2: FRE .num

!
