-- ===== WRITE OUTPUT =====
.opath: "out.exe"
.oh: FOP .opath .one
.owlen: FWR .oh .pe 2560
.oc: FCL .oh

-- ===== DISPLAY =====
.hdr: "Gen18: File I/O Compiler\n"
.ph: PRT .hdr 25

.msg1: "Filename length: "
.pm1: PRT .msg1 17
.num: ALC 8
.its1: ITS .fn_len .num
.pn1: PRT .num .its1

.msg2: "\nContent length: "
.pm2: PRT .msg2 17
.its2: ITS .ct_len .num
.pn2: PRT .num .its2

.nl: "\n-> out.exe generated\n"
.pnl: PRT .nl 22

.f1: FRE .pe
.f2: FRE .ibuf
.f3: FRE .num

!
