.x0: PUT .pe 512 72
.x1: PUT .pe 513 131
.x2: PUT .pe 514 236
.x3: PUT .pe 515 72

-- lea rcx, [rip+0x75] (filename at RVA 0x1080, RIP=0x100B)
.x4: PUT .pe 516 72
.x5: PUT .pe 517 141
.x6: PUT .pe 518 13
.x7: PUT .pe 519 117
.x8: PUT .pe 520 0
.x9: PUT .pe 521 0
.x10: PUT .pe 522 0

-- mov edx, 0x40000000 (GENERIC_WRITE)
.x11: PUT .pe 523 186
.x12: PUT .pe 524 0
.x13: PUT .pe 525 0
.x14: PUT .pe 526 0
.x15: PUT .pe 527 64

-- xor r8d, r8d (dwShareMode=0)
