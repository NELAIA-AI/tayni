-- TAYNI Gen18 - File I/O Compiler
-- Compiles programs that write files
-- Input format:
--   .path: "filename.txt"
--   .msg: "content to write"
--   .h: FOP .path 1
--   .w: FWR .h .msg LEN
--   .c: FCL .h
--   !
-- Imports: CreateFileA, WriteFile, CloseHandle, ExitProcess
-- Date: 2026-06-16

.zero: 0
.one: 1

-- ===== READ PROGRAM =====
.ipath: "program.tyn"
.ih: FOP .ipath .zero
.ibuf: ALC 512
.ilen: FRD .ih .ibuf 512
.ic: FCL .ih

-- ===== PARSE FIRST STRING (filename) =====
-- Find first quote at byte 7 (format: .path: "...)
-- Actually scan for first quote
.b4: GET .ibuf 4
.b5: GET .ibuf 5
.b6: GET .ibuf 6
.b7: GET .ibuf 7
.b8: GET .ibuf 8

.q4: SUB .b4 34
.q5: SUB .b5 34
.q6: SUB .b6 34
.q7: SUB .b7 34
.q8: SUB .b8 34

-- First quote position
.fq8: IFZ .q8 8 9
.fq7: IFZ .q7 7 .fq8
.fq6: IFZ .q6 6 .fq7
.fq5: IFZ .q5 5 .fq6
.first_q: IFZ .q4 4 .fq5

-- Filename starts at first_q + 1
.fn_start: ADD .first_q 1

-- Scan for closing quote of filename (bytes fn_start to fn_start+15)
.fn0: GET .ibuf .fn_start
.fs1: ADD .fn_start 1
.fn1: GET .ibuf .fs1
.fs2: ADD .fn_start 2
.fn2: GET .ibuf .fs2
.fs3: ADD .fn_start 3
.fn3: GET .ibuf .fs3
.fs4: ADD .fn_start 4
.fn4: GET .ibuf .fs4
.fs5: ADD .fn_start 5
.fn5: GET .ibuf .fs5
.fs6: ADD .fn_start 6
.fn6: GET .ibuf .fs6
.fs7: ADD .fn_start 7
.fn7: GET .ibuf .fs7
.fs8: ADD .fn_start 8
.fn8: GET .ibuf .fs8
.fs9: ADD .fn_start 9
.fn9: GET .ibuf .fs9
.fs10: ADD .fn_start 10
.fn10: GET .ibuf .fs10
.fs11: ADD .fn_start 11
.fn11: GET .ibuf .fs11

.fne11: SUB .fn11 34
.fne10: SUB .fn10 34
.fne9: SUB .fn9 34
.fne8: SUB .fn8 34
.fne7: SUB .fn7 34
.fne6: SUB .fn6 34
.fne5: SUB .fn5 34
.fne4: SUB .fn4 34
.fne3: SUB .fn3 34
.fne2: SUB .fn2 34
.fne1: SUB .fn1 34
.fne0: SUB .fn0 34

.fnp11: IFZ .fne11 11 12
.fnp10: IFZ .fne10 10 .fnp11
.fnp9: IFZ .fne9 9 .fnp10
.fnp8: IFZ .fne8 8 .fnp9
.fnp7: IFZ .fne7 7 .fnp8
.fnp6: IFZ .fne6 6 .fnp7
.fnp5: IFZ .fne5 5 .fnp6
.fnp4: IFZ .fne4 4 .fnp5
.fnp3: IFZ .fne3 3 .fnp4
.fnp2: IFZ .fne2 2 .fnp3
.fnp1: IFZ .fne1 1 .fnp2
.fn_len: IFZ .fne0 0 .fnp1

-- ===== FIND SECOND STRING (content) =====
-- Second line starts after first \n
-- Scan for \n after the first quote section
.fn_end_abs: ADD .fn_start .fn_len
.fn_end_1: ADD .fn_end_abs 1
-- Next newline is at fn_end_1 + some bytes
.nl_s0: GET .ibuf .fn_end_1
.nl_a1: ADD .fn_end_1 1
.nl_s1: GET .ibuf .nl_a1
.nl_a2: ADD .fn_end_1 2
.nl_s2: GET .ibuf .nl_a2

.nl_n0: SUB .nl_s0 10
.nl_n1: SUB .nl_s1 10
.nl_n2: SUB .nl_s2 10

.nl_p2: IFZ .nl_n2 .nl_a2 .nl_a2
.nl_p1: IFZ .nl_n1 .nl_a1 .nl_p2
.nl_pos: IFZ .nl_n0 .fn_end_1 .nl_p1

-- Line 2 starts after newline
.l2_start: ADD .nl_pos 1

-- Find quote in line 2
.l2_q0: ADD .l2_start 4
.l2_q1: ADD .l2_start 5
.l2_q2: ADD .l2_start 6
.l2_q3: ADD .l2_start 7
.l2_q4: ADD .l2_start 8

.l2_c0: GET .ibuf .l2_q0
.l2_c1: GET .ibuf .l2_q1
.l2_c2: GET .ibuf .l2_q2
.l2_c3: GET .ibuf .l2_q3
.l2_c4: GET .ibuf .l2_q4

.l2_e0: SUB .l2_c0 34
.l2_e1: SUB .l2_c1 34
.l2_e2: SUB .l2_c2 34
.l2_e3: SUB .l2_c3 34
.l2_e4: SUB .l2_c4 34

.l2_p4: IFZ .l2_e4 .l2_q4 .l2_q4
.l2_p3: IFZ .l2_e3 .l2_q3 .l2_p4
.l2_p2: IFZ .l2_e2 .l2_q2 .l2_p3
.l2_p1: IFZ .l2_e1 .l2_q1 .l2_p2
.l2_qpos: IFZ .l2_e0 .l2_q0 .l2_p1

-- Content starts after this quote
.ct_start: ADD .l2_qpos 1

-- Scan for closing quote of content (up to 20 chars)
.ct0: GET .ibuf .ct_start
.ca1: ADD .ct_start 1
.ct1: GET .ibuf .ca1
.ca2: ADD .ct_start 2
.ct2: GET .ibuf .ca2
.ca3: ADD .ct_start 3
.ct3: GET .ibuf .ca3
.ca4: ADD .ct_start 4
.ct4: GET .ibuf .ca4
.ca5: ADD .ct_start 5
.ct5: GET .ibuf .ca5
.ca6: ADD .ct_start 6
.ct6: GET .ibuf .ca6
.ca7: ADD .ct_start 7
.ct7: GET .ibuf .ca7
.ca8: ADD .ct_start 8
.ct8: GET .ibuf .ca8
.ca9: ADD .ct_start 9
.ct9: GET .ibuf .ca9
.ca10: ADD .ct_start 10
.ct10: GET .ibuf .ca10
.ca11: ADD .ct_start 11
.ct11: GET .ibuf .ca11
.ca12: ADD .ct_start 12
.ct12: GET .ibuf .ca12
.ca13: ADD .ct_start 13
.ct13: GET .ibuf .ca13
.ca14: ADD .ct_start 14
.ct14: GET .ibuf .ca14
.ca15: ADD .ct_start 15
.ct15: GET .ibuf .ca15

.cte15: SUB .ct15 34
.cte14: SUB .ct14 34
.cte13: SUB .ct13 34
.cte12: SUB .ct12 34
.cte11: SUB .ct11 34
.cte10: SUB .ct10 34
.cte9: SUB .ct9 34
.cte8: SUB .ct8 34
.cte7: SUB .ct7 34
.cte6: SUB .ct6 34
.cte5: SUB .ct5 34
.cte4: SUB .ct4 34
.cte3: SUB .ct3 34
.cte2: SUB .ct2 34
.cte1: SUB .ct1 34
.cte0: SUB .ct0 34

.ctp15: IFZ .cte15 15 16
.ctp14: IFZ .cte14 14 .ctp15
.ctp13: IFZ .cte13 13 .ctp14
.ctp12: IFZ .cte12 12 .ctp13
.ctp11: IFZ .cte11 11 .ctp12
.ctp10: IFZ .cte10 10 .ctp11
.ctp9: IFZ .cte9 9 .ctp10
.ctp8: IFZ .cte8 8 .ctp9
.ctp7: IFZ .cte7 7 .ctp8
.ctp6: IFZ .cte6 6 .ctp7
.ctp5: IFZ .cte5 5 .ctp6
.ctp4: IFZ .cte4 4 .ctp5
.ctp3: IFZ .cte3 3 .ctp4
.ctp2: IFZ .cte2 2 .ctp3
.ctp1: IFZ .cte1 1 .ctp2
.ct_len: IFZ .cte0 0 .ctp1

-- ===== BUILD PE =====
.pe: ALC 4096

-- DOS Header
.dos0: PUT .pe 0 77
.dos1: PUT .pe 1 90
.dos60: PUT .pe 60 64

-- PE Signature
.pe64: PUT .pe 64 80
.pe65: PUT .pe 65 69

-- COFF Header
.coff0: PUT .pe 68 100
.coff1: PUT .pe 69 134
.coff2: PUT .pe 70 2
.coff16: PUT .pe 84 240
.coff18: PUT .pe 86 34

-- Optional Header (same as gen17)
.opt0: PUT .pe 88 11
.opt1: PUT .pe 89 2
.opt2: PUT .pe 90 0
.opt3: PUT .pe 91 4
.opt16: PUT .pe 104 0
.opt17: PUT .pe 105 16
.opt20: PUT .pe 108 0
.opt21: PUT .pe 109 16
.opt27: PUT .pe 115 64
.opt28: PUT .pe 116 1
.opt32: PUT .pe 120 0
