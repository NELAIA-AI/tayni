-- TAYNI Test GET then ADD
-- Read from buffer, add 23, print as char

.zero: 0

.data: ALC 64
.out: ALC 64

-- Store 42 in data buffer
@.store: PUT .data 0 42

-- Read from data buffer
@.val: GET .data 0

-- Add 23 to get 65 (A)
@.val2: ADD @.val 23

-- Store in out buffer
@.put_out: PUT .out 0 @.val2

-- Print 1 byte (should be A)
.done: PRT .out 1

!
