-- mov r8d, r14d
.c84: PUT .pe 596 69
.c85: PUT .pe 597 137
.c86: PUT .pe 598 240
-- lea r9, [rsp+56]
.c87: PUT .pe 599 76
.c88: PUT .pe 600 141
.c89: PUT .pe 601 76
.c90: PUT .pe 602 36
.c91: PUT .pe 603 56
-- mov qword [rsp+32], 0
.c92: PUT .pe 604 72
.c93: PUT .pe 605 199
.c94: PUT .pe 606 68
.c95: PUT .pe 607 36
.c96: PUT .pe 608 32
.c97: PUT .pe 609 0
.c98: PUT .pe 610 0
.c99: PUT .pe 611 0
.c100: PUT .pe 612 0
-- call WriteFile (IAT[1]=0x2108, RIP=0x106B, disp=0x109D)
.c101: PUT .pe 613 255
.c102: PUT .pe 614 21
.c103: PUT .pe 615 157
.c104: PUT .pe 616 16
.c105: PUT .pe 617 0
.c106: PUT .pe 618 0

-- === EXIT ===
