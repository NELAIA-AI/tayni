.c71: PUT .pe 583 181
.c72: PUT .pe 584 16
.c73: PUT .pe 585 0
.c74: PUT .pe 586 0

-- mov rbx, rax (stdout handle)
.c75: PUT .pe 587 72
.c76: PUT .pe 588 137
.c77: PUT .pe 589 195

