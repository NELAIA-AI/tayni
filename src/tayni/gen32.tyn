-- ===== WRITE OUTPUT =====
.opath: "out.exe"
.oh: FOP .opath .one
.owlen: FWR .oh .pe 2560
.oc: FCL .oh

-- ===== STATUS =====
.hdr: "Gen32: Simple 3-line compiler\n"
.ph: PRT .hdr 30
.msg1: "Input: .a="
.pm1: PRT .msg1 10
.num: ALC 8
.its1: ITS .val_a .num
.pn1: PRT .num .its1
.msg2: " .b="
.pm2: PRT .msg2 4
.its2: ITS .val_b .num
.pn2: PRT .num .its2
.msg3: "\nResult: "
.pm3: PRT .msg3 9
.its3: ITS .result .num
.pn3: PRT .num .its3
.nl: "\n-> out.exe created\n"
.pnl: PRT .nl 19

.f1: FRE .pe
.f2: FRE .ibuf
.f3: FRE .num

!
