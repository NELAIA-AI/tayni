.opt81: PUT .pe 169 16
.opt90: PUT .pe 178 16
.opt97: PUT .pe 185 16
.opt108: PUT .pe 196 16

-- Data Directories
.dd_imp0: PUT .pe 208 0
.dd_imp1: PUT .pe 209 32
.dd_imp_sz: PUT .pe 212 40
.dd_iat0: PUT .pe 296 0
.dd_iat1: PUT .pe 297 33
.dd_iat_sz: PUT .pe 300 48

-- Section .text
.st0: PUT .pe 328 46
.st1: PUT .pe 329 116
.st2: PUT .pe 330 101
.st3: PUT .pe 331 120
.st4: PUT .pe 332 116
.st_vs: PUT .pe 337 4
.st_va1: PUT .pe 341 16
.st_rd: PUT .pe 345 4
.st_rp1: PUT .pe 349 2
.st_ch0: PUT .pe 364 32
.st_ch3: PUT .pe 367 96

-- Section .rdata
.sr0: PUT .pe 368 46
.sr1: PUT .pe 369 114
.sr2: PUT .pe 370 100
.sr3: PUT .pe 371 97
.sr4: PUT .pe 372 116
.sr5: PUT .pe 373 97
.sr_vs1: PUT .pe 377 4
.sr_va1: PUT .pe 381 32
.sr_rd1: PUT .pe 385 4
.sr_rp1: PUT .pe 389 6
.sr_ch0: PUT .pe 404 64
.sr_ch3: PUT .pe 407 64

-- ===== CODE at file 512 (RVA 0x1000) =====
-- sub rsp, 0x78
.c0: PUT .pe 512 72
.c1: PUT .pe 513 131
.c2: PUT .pe 514 236
.c3: PUT .pe 515 120

-- mov eax, result (embedded at compile time)
.c4: PUT .pe 516 184
.c5: PUT .pe 517 .result
.c6: PUT .pe 518 0
.c7: PUT .pe 519 0
.c8: PUT .pe 520 0

-- mov r12d, eax (save result)
.c9: PUT .pe 521 65
.c10: PUT .pe 522 137
.c11: PUT .pe 523 196

-- xor r13d, r13d (digit count)
.c12: PUT .pe 524 69
.c13: PUT .pe 525 49
.c14: PUT .pe 526 237

-- mov ecx, 10 (divisor)
.c15: PUT .pe 527 185
.c16: PUT .pe 528 10
.c17: PUT .pe 529 0
.c18: PUT .pe 530 0
.c19: PUT .pe 531 0

-- Digit 0 (ones): eax % 10
-- xor edx, edx
.c20: PUT .pe 532 49
.c21: PUT .pe 533 210
-- div ecx
.c22: PUT .pe 534 247
.c23: PUT .pe 535 241
-- add dl, '0'
.c24: PUT .pe 536 128
.c25: PUT .pe 537 194
.c26: PUT .pe 538 48
-- mov [rsp+50], dl
.c27: PUT .pe 539 136
.c28: PUT .pe 540 84
.c29: PUT .pe 541 36
.c30: PUT .pe 542 50

-- Digit 1 (tens): eax % 10
-- xor edx, edx
.c31: PUT .pe 543 49
.c32: PUT .pe 544 210
-- div ecx
.c33: PUT .pe 545 247
.c34: PUT .pe 546 241
-- add dl, '0'
.c35: PUT .pe 547 128
.c36: PUT .pe 548 194
.c37: PUT .pe 549 48
-- mov [rsp+49], dl
.c38: PUT .pe 550 136
.c39: PUT .pe 551 84
.c40: PUT .pe 552 36
.c41: PUT .pe 553 49

-- Digit 2 (hundreds): eax % 10
-- xor edx, edx
.c42: PUT .pe 554 49
.c43: PUT .pe 555 210
-- div ecx
.c44: PUT .pe 556 247
.c45: PUT .pe 557 241
-- add dl, '0'
.c46: PUT .pe 558 128
.c47: PUT .pe 559 194
.c48: PUT .pe 560 48
-- mov [rsp+48], dl
.c49: PUT .pe 561 136
.c50: PUT .pe 562 84
.c51: PUT .pe 563 36
.c52: PUT .pe 564 48

-- lea rsi, [rsp+49] (string start for 2 digits)
.c53: PUT .pe 565 72
.c54: PUT .pe 566 141
.c55: PUT .pe 567 116
.c56: PUT .pe 568 36
.c57: PUT .pe 569 49

-- mov r14d, 2 (length)
.c58: PUT .pe 570 65
.c59: PUT .pe 571 190
.c60: PUT .pe 572 2
.c61: PUT .pe 573 0
.c62: PUT .pe 574 0
.c63: PUT .pe 575 0

-- === PRT: GetStdHandle + WriteFile ===
-- mov ecx, -11
.c64: PUT .pe 576 185
.c65: PUT .pe 577 245
.c66: PUT .pe 578 255
.c67: PUT .pe 579 255
.c68: PUT .pe 580 255
-- call GetStdHandle (IAT[0]=0x2100, RIP=0x104B, disp=0x10B5)
.c69: PUT .pe 581 255
