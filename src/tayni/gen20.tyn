-- TAYNI Gen20 - Multi-Operation Compiler
-- Compiles programs with PRT + File I/O combined
-- Input format:
--   .msg: "message string"
--   .path: "filename.txt"
--   .p: PRT .msg LEN
--   .h: FOP .path 1
--   .w: FWR .h .msg LEN
--   .c: FCL .h
--   !
-- Imports: KERNEL32 (GetStdHandle, WriteFile, CreateFileA, CloseHandle)
-- Date: 2026-06-16

.zero: 0
.one: 1

-- ===== READ PROGRAM =====
.ipath: "program.tyn"
.ih: FOP .ipath .zero
.ibuf: ALC 512
.ilen: FRD .ih .ibuf 512
.ic: FCL .ih

-- ===== PARSE FIRST STRING (msg) =====
.b5: GET .ibuf 5
.b6: GET .ibuf 6
.b7: GET .ibuf 7
.q5: SUB .b5 34
.q6: SUB .b6 34
.q7: SUB .b7 34
.fq7: IFZ .q7 7 8
.fq6: IFZ .q6 6 .fq7
.first_q: IFZ .q5 5 .fq6
.msg_start: ADD .first_q 1

-- Extract msg bytes (up to 32)
.m0: GET .ibuf .msg_start
.ma1: ADD .msg_start 1
.m1: GET .ibuf .ma1
.ma2: ADD .msg_start 2
.m2: GET .ibuf .ma2
.ma3: ADD .msg_start 3
.m3: GET .ibuf .ma3
.ma4: ADD .msg_start 4
.m4: GET .ibuf .ma4
.ma5: ADD .msg_start 5
.m5: GET .ibuf .ma5
.ma6: ADD .msg_start 6
.m6: GET .ibuf .ma6
.ma7: ADD .msg_start 7
.m7: GET .ibuf .ma7
.ma8: ADD .msg_start 8
.m8: GET .ibuf .ma8
.ma9: ADD .msg_start 9
.m9: GET .ibuf .ma9
.ma10: ADD .msg_start 10
.m10: GET .ibuf .ma10
.ma11: ADD .msg_start 11
.m11: GET .ibuf .ma11
.ma12: ADD .msg_start 12
.m12: GET .ibuf .ma12
.ma13: ADD .msg_start 13
.m13: GET .ibuf .ma13
.ma14: ADD .msg_start 14
.m14: GET .ibuf .ma14
.ma15: ADD .msg_start 15
.m15: GET .ibuf .ma15

-- Find msg length (closing quote)
.me0: SUB .m0 34
.me1: SUB .m1 34
.me2: SUB .m2 34
.me3: SUB .m3 34
.me4: SUB .m4 34
.me5: SUB .m5 34
.me6: SUB .m6 34
.me7: SUB .m7 34
.me8: SUB .m8 34
.me9: SUB .m9 34
.me10: SUB .m10 34
.me11: SUB .m11 34
.me12: SUB .m12 34
.me13: SUB .m13 34
.me14: SUB .m14 34
.me15: SUB .m15 34

.mp15: IFZ .me15 15 16
.mp14: IFZ .me14 14 .mp15
.mp13: IFZ .me13 13 .mp14
.mp12: IFZ .me12 12 .mp13
.mp11: IFZ .me11 11 .mp12
.mp10: IFZ .me10 10 .mp11
.mp9: IFZ .me9 9 .mp10
.mp8: IFZ .me8 8 .mp9
.mp7: IFZ .me7 7 .mp8
.mp6: IFZ .me6 6 .mp7
.mp5: IFZ .me5 5 .mp6
.mp4: IFZ .me4 4 .mp5
.mp3: IFZ .me3 3 .mp4
.mp2: IFZ .me2 2 .mp3
.mp1: IFZ .me1 1 .mp2
.msg_len: IFZ .me0 0 .mp1

-- ===== FIND SECOND LINE (path) =====
.msg_end: ADD .msg_start .msg_len
.line2_start: ADD .msg_end 3

-- Find quote in line 2
.l2a5: ADD .line2_start 5
.l2a6: ADD .line2_start 6
.l2a7: ADD .line2_start 7
.l2b5: GET .ibuf .l2a5
.l2b6: GET .ibuf .l2a6
.l2b7: GET .ibuf .l2a7
.l2q5: SUB .l2b5 34
.l2q6: SUB .l2b6 34
.l2q7: SUB .l2b7 34
.l2fq7: IFZ .l2q7 .l2a7 .l2a7
.l2fq6: IFZ .l2q6 .l2a6 .l2fq7
.path_q: IFZ .l2q5 .l2a5 .l2fq6
.path_start: ADD .path_q 1

-- Extract path bytes (up to 12)
.p0: GET .ibuf .path_start
.pa1: ADD .path_start 1
.p1: GET .ibuf .pa1
.pa2: ADD .path_start 2
.p2: GET .ibuf .pa2
.pa3: ADD .path_start 3
.p3: GET .ibuf .pa3
.pa4: ADD .path_start 4
.p4: GET .ibuf .pa4
.pa5: ADD .path_start 5
.p5: GET .ibuf .pa5
.pa6: ADD .path_start 6
.p6: GET .ibuf .pa6
.pa7: ADD .path_start 7
.p7: GET .ibuf .pa7
.pa8: ADD .path_start 8
.p8: GET .ibuf .pa8
.pa9: ADD .path_start 9
.p9: GET .ibuf .pa9
.pa10: ADD .path_start 10
.p10: GET .ibuf .pa10
.pa11: ADD .path_start 11
.p11: GET .ibuf .pa11

-- Find path length
.pe0: SUB .p0 34
.pe1: SUB .p1 34
.pe2: SUB .p2 34
.pe3: SUB .p3 34
.pe4: SUB .p4 34
.pe5: SUB .p5 34
.pe6: SUB .p6 34
.pe7: SUB .p7 34
.pe8: SUB .p8 34
.pe9: SUB .p9 34
.pe10: SUB .p10 34
.pe11: SUB .p11 34

.pp11: IFZ .pe11 11 12
.pp10: IFZ .pe10 10 .pp11
.pp9: IFZ .pe9 9 .pp10
.pp8: IFZ .pe8 8 .pp9
.pp7: IFZ .pe7 7 .pp8
.pp6: IFZ .pe6 6 .pp7
.pp5: IFZ .pe5 5 .pp6
.pp4: IFZ .pe4 4 .pp5
.pp3: IFZ .pe3 3 .pp4
.pp2: IFZ .pe2 2 .pp3
.pp1: IFZ .pe1 1 .pp2
.path_len: IFZ .pe0 0 .pp1

-- ===== BUILD PE (3072 bytes) =====
.pe: ALC 4096

-- DOS Header
.dos0: PUT .pe 0 77
.dos1: PUT .pe 1 90
.dos60: PUT .pe 60 64

-- PE Signature
.pe64: PUT .pe 64 80
.pe65: PUT .pe 65 69

-- COFF Header
.coff0: PUT .pe 68 100
.coff1: PUT .pe 69 134
.coff2: PUT .pe 70 2
.coff84: PUT .pe 84 240
.coff86: PUT .pe 86 34

-- Optional Header PE32+
