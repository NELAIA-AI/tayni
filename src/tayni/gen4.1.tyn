-- ===== CÓDIGO MÁQUINA EN outpe =====
-- mov eax, <value>; ret
-- El valor se insertará dinámicamente

-- Por ahora, valor fijo 42 para test
.x0: PUT .outpe 512 184
.x1: PUT .outpe 513 42
.x2: PUT .outpe 514 0
.x3: PUT .outpe 515 0
.x4: PUT .outpe 516 0
.x5: PUT .outpe 517 195

-- ===== ESCRIBIR gen4.exe (compilador) =====
.opath: "gen4.exe"
.oh: FOP .opath .one
.wlen: FWR .oh .template .tlen
.oc: FCL .oh

-- ===== ESCRIBIR compiled.exe (output) =====
.opath2: "compiled.exe"
.oh2: FOP .opath2 .one
.size2: 1024
.wlen2: FWR .oh2 .outpe .size2
.oc2: FCL .oh2

.hdr: "Gen4.1: Compilador + Output\n"
.p0: PRT .hdr 28

.f1: FRE .template
.f2: FRE .outpe

!
