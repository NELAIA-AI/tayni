-- TAYNI Gen4.1 - Compilador Autónomo Completo
-- Lee input.tyn, genera compiled.exe
-- TODO usando syscalls (sin Rust)
-- Fecha: 2026-06-16

.zero: 0
.one: 1

-- Template con imports
.template: ALC 8192
.tpath: "fileio2.exe.exe"
.th: FOP .tpath .zero
.tlen: FRD .th .template 8192
.tc: FCL .th

-- Buffer para PE de salida
.outpe: ALC 2048

-- ===== GENERAR PE HEADER EN outpe =====

-- DOS Header
.h0: PUT .outpe 0 77
.h1: PUT .outpe 1 90
.h60: PUT .outpe 60 64

-- PE Signature at 0x40
.h64: PUT .outpe 64 80
.h65: PUT .outpe 65 69

-- COFF Header
.h68: PUT .outpe 68 100
.h69: PUT .outpe 69 134
.h70: PUT .outpe 70 1
.h84: PUT .outpe 84 240
.h86: PUT .outpe 86 34

-- Optional Header PE32+
.h88: PUT .outpe 88 11
.h89: PUT .outpe 89 2
.h93: PUT .outpe 93 2
.h105: PUT .outpe 105 16
.h109: PUT .outpe 109 16
.h115: PUT .outpe 115 64
.h116: PUT .outpe 116 1
.h121: PUT .outpe 121 16
.h125: PUT .outpe 125 2
.h128: PUT .outpe 128 6
.h136: PUT .outpe 136 6
.h145: PUT .outpe 145 32
.h149: PUT .outpe 149 2
.h156: PUT .outpe 156 3
.h158: PUT .outpe 158 96
.h159: PUT .outpe 159 129
.h162: PUT .outpe 162 16
.h169: PUT .outpe 169 16
.h178: PUT .outpe 178 16
.h185: PUT .outpe 185 16
.h196: PUT .outpe 196 16

-- Section Header .text
