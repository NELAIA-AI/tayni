-- ===== DECIDIR OUTPUT =====
-- Si es comentario -> escribir copia del compilador
-- Si no -> escribir PE generado

.out_buf: IFZ .is_comment .self .pe
.out_len: IFZ .is_comment .slen 2560

-- Escribir out.exe
.opath: "out.exe"
.oh: FOP .opath .one
.owlen: FWR .oh .out_buf .out_len
.oc: FCL .oh

-- Output
.hdr: "Gen15: Zero Rust Compiler\n"
.ph: PRT .hdr 26

.msg_val: "Valor: "
.pmv: PRT .msg_val 7
.num: ALC 8
.its: ITS .val .num
.pn: PRT .num .its
.nl: "\n"
.pnl: PRT .nl 1

.msg_out: "-> out.exe generado\n"
.pmo: PRT .msg_out 20

.f1: FRE .pe
.f2: FRE .self
.f3: FRE .ibuf
.f4: FRE .num

!
