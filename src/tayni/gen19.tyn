-- TAYNI Gen19 - TCP Server Compiler
-- Compiles programs that serve TCP connections
-- Input: .msg: "response string" then !
-- Output: PE that listens on port 8080, accepts 1 connection,
--         sends the response, then exits
-- Imports: WS2_32.dll (WSAStartup,socket,bind,listen,accept,send,closesocket,WSACleanup)
--          KERNEL32.dll (ExitProcess)
-- Date: 2026-06-16

.zero: 0
.one: 1

-- ===== READ PROGRAM =====
.ipath: "program.tyn"
.ih: FOP .ipath .zero
.ibuf: ALC 512
.ilen: FRD .ih .ibuf 512
.ic: FCL .ih

-- ===== PARSE STRING =====
-- Format: .msg: "..."
-- Find first quote
.b4: GET .ibuf 4
.b5: GET .ibuf 5
.b6: GET .ibuf 6
.b7: GET .ibuf 7

.q4: SUB .b4 34
.q5: SUB .b5 34
.q6: SUB .b6 34
.q7: SUB .b7 34

.fq7: IFZ .q7 7 8
.fq6: IFZ .q6 6 .fq7
.fq5: IFZ .q5 5 .fq6
.first_q: IFZ .q4 4 .fq5

.msg_start: ADD .first_q 1

-- Extract up to 48 bytes of message
.m0: GET .ibuf .msg_start
.ma1: ADD .msg_start 1
.m1: GET .ibuf .ma1
.ma2: ADD .msg_start 2
.m2: GET .ibuf .ma2
.ma3: ADD .msg_start 3
.m3: GET .ibuf .ma3
