.m13: GET .ibuf .ma13
.ma14: ADD .msg_start 14
.m14: GET .ibuf .ma14
.ma15: ADD .msg_start 15
.m15: GET .ibuf .ma15
.ma16: ADD .msg_start 16
.m16: GET .ibuf .ma16
.ma17: ADD .msg_start 17
.m17: GET .ibuf .ma17
.ma18: ADD .msg_start 18
.m18: GET .ibuf .ma18
.ma19: ADD .msg_start 19
.m19: GET .ibuf .ma19
.ma20: ADD .msg_start 20
.m20: GET .ibuf .ma20
.ma21: ADD .msg_start 21
.m21: GET .ibuf .ma21
.ma22: ADD .msg_start 22
.m22: GET .ibuf .ma22
.ma23: ADD .msg_start 23
.m23: GET .ibuf .ma23
.ma24: ADD .msg_start 24
.m24: GET .ibuf .ma24
.ma25: ADD .msg_start 25
.m25: GET .ibuf .ma25
.ma26: ADD .msg_start 26
.m26: GET .ibuf .ma26
.ma27: ADD .msg_start 27
.m27: GET .ibuf .ma27
.ma28: ADD .msg_start 28
.m28: GET .ibuf .ma28
.ma29: ADD .msg_start 29
.m29: GET .ibuf .ma29
.ma30: ADD .msg_start 30
.m30: GET .ibuf .ma30
.ma31: ADD .msg_start 31
.m31: GET .ibuf .ma31

-- Find closing quote (message length)
.me0: SUB .m0 34
.me1: SUB .m1 34
.me2: SUB .m2 34
.me3: SUB .m3 34
.me4: SUB .m4 34
.me5: SUB .m5 34
