-- TAYNI Test ITS with ADD
-- Use ADD to verify the value, then ITS

.zero: 0

.data: ALC 64
.out: ALC 64

-- Store 42 in data buffer
@.store: PUT .data 0 42

-- Read from data buffer
@.val: GET .data 0

-- Add 0 to verify the value
@.val2: ADD @.val .zero

-- Convert to string in out buffer
@.len: ITS @.val2 .out

-- Print from out buffer
.done: PRT .out @.len

!
