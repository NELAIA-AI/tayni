-- TAYNI Test Value Chain
-- Verify the value chain works

.zero: 0

.data: ALC 64
.out: ALC 64

-- Store 65 (A) in data buffer
@.store: PUT .data 0 65

-- Read from data buffer
@.val: GET .data 0

-- Store the value in out buffer
@.put_out: PUT .out 0 @.val

-- Print 1 byte from out buffer (should be A)
.done: PRT .out 1

!
