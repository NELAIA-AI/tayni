-- Escribir out.exe
.opath: "out.exe"
.oh: FOP .opath .one
.pe_size: 1536
.owlen: FWR .oh .pe .pe_size
.oc: FCL .oh

-- Output
.hdr: "Gen13: PE con IAT\n"
.ph: PRT .hdr 18

.msg_val: "Valor: "
.pmv: PRT .msg_val 7
.num: ALC 8
.its: ITS .val .num
.pn: PRT .num .its
.nl: "\n"
.pnl: PRT .nl 1

.msg_out: "-> out.exe (1536 bytes, con IAT)\n"
.pmo: PRT .msg_out 33

.f1: FRE .pe
.f2: FRE .self
.f3: FRE .ibuf
.f4: FRE .num

!
