-- Escribir out.exe
.opath: "out.exe"
.oh: FOP .opath .one
.pe_size: 2560
.owlen: FWR .oh .pe .pe_size
.oc: FCL .oh

-- Output
.hdr: "Gen14: PE con File I/O\n"
.ph: PRT .hdr 23

.msg_val: "Valor: "
.pmv: PRT .msg_val 7
.num: ALC 8
.its: ITS .val .num
.pn: PRT .num .its
.nl: "\n"
.pnl: PRT .nl 1

.msg_imp: "Imports: ExitProcess, CreateFileA, ReadFile,\n"
.pmi: PRT .msg_imp 46
.msg_imp2: "         WriteFile, CloseHandle, GetStdHandle,\n"
.pmi2: PRT .msg_imp2 47
.msg_imp3: "         VirtualAlloc, VirtualFree\n"
.pmi3: PRT .msg_imp3 35

.msg_out: "-> out.exe (2560 bytes)\n"
.pmo: PRT .msg_out 24

.f1: FRE .pe
.f2: FRE .self
.f3: FRE .ibuf
.f4: FRE .num

!
