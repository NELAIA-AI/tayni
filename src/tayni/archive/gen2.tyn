-- ============================================
-- CODE at 1024 (0x400)
-- Minimal: call ExitProcess(0)
-- ============================================

-- sub rsp, 40 (shadow space)
.c0: PUT .exe 1024 72
.c1: PUT .exe 1025 131
.c2: PUT .exe 1026 236
.c3: PUT .exe 1027 40

-- xor ecx, ecx (exit code 0)
.c4: PUT .exe 1028 49
.c5: PUT .exe 1029 201

-- call [ExitProcess] - will be at RVA 0x2050
-- call qword ptr [rip + offset]
.c6: PUT .exe 1030 255
.c7: PUT .exe 1031 21
.c8: PUT .exe 1032 26
.c9: PUT .exe 1033 16
.c10: PUT .exe 1034 0
.c11: PUT .exe 1035 0

