-- TAYNI Gen2 - Syscalls Puros
-- File I/O sin Rust - syscalls directos
-- Autonomía Total Completa
-- Fecha: 2026-06-16

-- Este programa genera un ejecutable que:
-- 1. Abre un archivo (NtOpenFile)
-- 2. Lee contenido (NtReadFile)
-- 3. Escribe a stdout (NtWriteFile)
-- 4. Sale (NtTerminateProcess)

-- Windows syscall numbers (Windows 10/11):
-- NtWriteFile = 0x08
-- NtReadFile = 0x06
-- NtOpenFile = 0x33
-- NtClose = 0x0F
-- NtTerminateProcess = 0x2C

.zero: 0
.one: 1

.exe: ALC 8192
.num: ALC 32

-- ============================================
-- PE HEADER (igual que Gen0.5 pero con imports)
-- ============================================

-- DOS Header
.w0: PUT .exe 0 77
.w1: PUT .exe 1 90
.w60: PUT .exe 60 128

