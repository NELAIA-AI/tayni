-- ============================================
-- ESCRIBIR EJECUTABLE
-- ============================================

.opath: "syscall.exe"
.oh: FOP .opath .one
.size: 4096
.wlen: FWR .oh .exe .size
.oc: FCL .oh

-- ============================================
-- OUTPUT
-- ============================================

.hdr: "Gen2 - Syscall Pure\n"
.p0: PRT .hdr 20

.ms: "Generated: syscall.exe\n"
.p1: PRT .ms 23

-- Cleanup
.f1: FRE .exe
.f2: FRE .num

!
