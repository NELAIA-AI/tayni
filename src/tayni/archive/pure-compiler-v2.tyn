-- TAYNI Pure Compiler v2.0
-- Genera PE con syscalls (file I/O)
-- Self-hosting ready
-- Fecha: 2026-06-16

-- ============================================================
-- PRINCIPIOS AI-NATIVE
-- ============================================================
-- 1. Sin loops: código desenrollado
-- 2. Sin saltos: BRN es operador ternario
-- 3. Sin templates: genera PE byte por byte
-- 4. Declarativo: cada línea es una transformación

.zero: 0
.one: 1

-- ============================================================
-- FASE 1: LEER ARCHIVO FUENTE
-- ============================================================
.src: ALC 4096
.srcpath: "input.tyn"
.srch: FOP .srcpath .zero
.srclen: FRD .srch .src 4096
.srcc: FCL .srch

-- ============================================================
-- FASE 2: LEXER - Extraer valor de ".x: N"
-- ============================================================
.b4: GET .src 4
.val: SUB .b4 48

-- ============================================================
-- FASE 3: GENERAR PE CON IMPORTS
-- ============================================================
.pe: ALC 8192

