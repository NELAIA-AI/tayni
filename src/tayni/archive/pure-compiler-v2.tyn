-- ============================================================
-- OUTPUT
-- ============================================================
.msg1: "TAYNI Pure Compiler v2.0\n"
.o1: PRT .msg1 25

.msg2: "Value: "
.o2: PRT .msg2 7
.num: ALC 16
.its: ITS .val .num
.o3: PRT .num .its
.nl: "\n"
.o4: PRT .nl 1

.msg3: "Output: pure2.exe (with imports)\n"
.o5: PRT .msg3 33

-- Cleanup
.f1: FRE .src
.f2: FRE .pe
.f3: FRE .num

!
