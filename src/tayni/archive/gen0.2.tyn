-- TAYNI Gen0.2 - Tokenizador Expandido
-- 64 bytes, múltiples nodos, sin FSM Rust
-- Autonomía Total
-- Fecha: 2026-06-16

-- ============================================
-- CONSTANTES
-- ============================================

.zero: 0
.one: 1

-- Códigos ASCII
.C_DOT: 46
.C_COLON: 58
.C_NL: 10
.C_SPACE: 32
.C_a: 97
.C_z: 122
.C_A: 65
.C_Z: 90
.C_0: 48
.C_9: 57

-- Tipos de token
.T_DOT: 1
.T_COLON: 2
.T_ID: 3
.T_NUM: 4

-- ============================================
-- BUFFERS
-- ============================================

.src: ALC 256
.num: ALC 32

-- ============================================
-- LEER ARCHIVO
-- ============================================

.path: "input.tyn"
.h: FOP .path .zero
.len: FRD .h .src 256
.c: FCL .h

-- ============================================
-- MACRO: CLASSIFY BYTE
-- Para cada byte: leer, clasificar tipo
-- ============================================

-- Byte 0
.r0: GET .src 0
.r0_dot: EQ .r0 .C_DOT
.r0_col: EQ .r0 .C_COLON
.r0_ga: GE .r0 .C_a
.r0_la: LE .r0 .C_z
.r0_lo: MUL .r0_ga .r0_la
.r0_gA: GE .r0 .C_A
.r0_lA: LE .r0 .C_Z
.r0_up: MUL .r0_gA .r0_lA
.r0_al: ADD .r0_lo .r0_up
.r0_g0: GE .r0 .C_0
.r0_l9: LE .r0 .C_9
.r0_dg: MUL .r0_g0 .r0_l9
.t0_a: MUL .r0_dot .T_DOT
.t0_b: MUL .r0_col .T_COLON
.t0_c: MUL .r0_al .T_ID
.t0_d: MUL .r0_dg .T_NUM
.t0_e: ADD .t0_a .t0_b
.t0_f: ADD .t0_e .t0_c
.t0: ADD .t0_f .t0_d

-- Byte 1
.r1: GET .src 1
.r1_dot: EQ .r1 .C_DOT
.r1_col: EQ .r1 .C_COLON
.r1_ga: GE .r1 .C_a
.r1_la: LE .r1 .C_z
.r1_lo: MUL .r1_ga .r1_la
.r1_gA: GE .r1 .C_A
.r1_lA: LE .r1 .C_Z
.r1_up: MUL .r1_gA .r1_lA
.r1_al: ADD .r1_lo .r1_up
.r1_g0: GE .r1 .C_0
.r1_l9: LE .r1 .C_9
.r1_dg: MUL .r1_g0 .r1_l9
.t1_a: MUL .r1_dot .T_DOT
.t1_b: MUL .r1_col .T_COLON
.t1_c: MUL .r1_al .T_ID
.t1_d: MUL .r1_dg .T_NUM
.t1_e: ADD .t1_a .t1_b
.t1_f: ADD .t1_e .t1_c
.t1: ADD .t1_f .t1_d

-- Byte 2
.r2: GET .src 2
.r2_dot: EQ .r2 .C_DOT
.r2_col: EQ .r2 .C_COLON
.r2_ga: GE .r2 .C_a
.r2_la: LE .r2 .C_z
.r2_lo: MUL .r2_ga .r2_la
.r2_gA: GE .r2 .C_A
.r2_lA: LE .r2 .C_Z
.r2_up: MUL .r2_gA .r2_lA
.r2_al: ADD .r2_lo .r2_up
.r2_g0: GE .r2 .C_0
.r2_l9: LE .r2 .C_9
.r2_dg: MUL .r2_g0 .r2_l9
.t2_a: MUL .r2_dot .T_DOT
.t2_b: MUL .r2_col .T_COLON
.t2_c: MUL .r2_al .T_ID
.t2_d: MUL .r2_dg .T_NUM
.t2_e: ADD .t2_a .t2_b
.t2_f: ADD .t2_e .t2_c
.t2: ADD .t2_f .t2_d

-- Byte 3
