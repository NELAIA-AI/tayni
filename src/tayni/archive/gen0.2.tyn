.r3_col: EQ .r3 .C_COLON
.r3_ga: GE .r3 .C_a
.r3_la: LE .r3 .C_z
.r3_lo: MUL .r3_ga .r3_la
.r3_gA: GE .r3 .C_A
.r3_lA: LE .r3 .C_Z
.r3_up: MUL .r3_gA .r3_lA
.r3_al: ADD .r3_lo .r3_up
.r3_g0: GE .r3 .C_0
.r3_l9: LE .r3 .C_9
.r3_dg: MUL .r3_g0 .r3_l9
.t3_a: MUL .r3_dot .T_DOT
.t3_b: MUL .r3_col .T_COLON
.t3_c: MUL .r3_al .T_ID
.t3_d: MUL .r3_dg .T_NUM
.t3_e: ADD .t3_a .t3_b
.t3_f: ADD .t3_e .t3_c
.t3: ADD .t3_f .t3_d

-- Byte 4
.r4: GET .src 4
.r4_dot: EQ .r4 .C_DOT
.r4_col: EQ .r4 .C_COLON
.r4_ga: GE .r4 .C_a
.r4_la: LE .r4 .C_z
.r4_lo: MUL .r4_ga .r4_la
.r4_gA: GE .r4 .C_A
.r4_lA: LE .r4 .C_Z
.r4_up: MUL .r4_gA .r4_lA
.r4_al: ADD .r4_lo .r4_up
.r4_g0: GE .r4 .C_0
.r4_l9: LE .r4 .C_9
.r4_dg: MUL .r4_g0 .r4_l9
.t4_a: MUL .r4_dot .T_DOT
.t4_b: MUL .r4_col .T_COLON
.t4_c: MUL .r4_al .T_ID
.t4_d: MUL .r4_dg .T_NUM
.t4_e: ADD .t4_a .t4_b
.t4_f: ADD .t4_e .t4_c
.t4: ADD .t4_f .t4_d

-- Byte 5
.r5: GET .src 5
.r5_dot: EQ .r5 .C_DOT
.r5_col: EQ .r5 .C_COLON
.r5_ga: GE .r5 .C_a
.r5_la: LE .r5 .C_z
.r5_lo: MUL .r5_ga .r5_la
.r5_gA: GE .r5 .C_A
.r5_lA: LE .r5 .C_Z
.r5_up: MUL .r5_gA .r5_lA
.r5_al: ADD .r5_lo .r5_up
.r5_g0: GE .r5 .C_0
.r5_l9: LE .r5 .C_9
.r5_dg: MUL .r5_g0 .r5_l9
.t5_a: MUL .r5_dot .T_DOT
.t5_b: MUL .r5_col .T_COLON
.t5_c: MUL .r5_al .T_ID
.t5_d: MUL .r5_dg .T_NUM
