-- Byte 9
.r9: GET .src 9
.r9_dot: EQ .r9 .C_DOT
.r9_col: EQ .r9 .C_COLON
.r9_ga: GE .r9 .C_a
.r9_la: LE .r9 .C_z
.r9_lo: MUL .r9_ga .r9_la
.r9_gA: GE .r9 .C_A
.r9_lA: LE .r9 .C_Z
.r9_up: MUL .r9_gA .r9_lA
.r9_al: ADD .r9_lo .r9_up
.r9_g0: GE .r9 .C_0
.r9_l9: LE .r9 .C_9
.r9_dg: MUL .r9_g0 .r9_l9
.t9_a: MUL .r9_dot .T_DOT
.t9_b: MUL .r9_col .T_COLON
.t9_c: MUL .r9_al .T_ID
.t9_d: MUL .r9_dg .T_NUM
.t9_e: ADD .t9_a .t9_b
.t9_f: ADD .t9_e .t9_c
.t9: ADD .t9_f .t9_d

-- Bytes 10-19 (para cubrir input.tyn de 20 bytes)
.r10: GET .src 10
.r10_dot: EQ .r10 .C_DOT
.t10: MUL .r10_dot .T_DOT

.r11: GET .src 11
.r11_ga: GE .r11 .C_a
.r11_la: LE .r11 .C_z
.r11_al: MUL .r11_ga .r11_la
.t11: MUL .r11_al .T_ID

.r12: GET .src 12
.r12_col: EQ .r12 .C_COLON
.t12: MUL .r12_col .T_COLON

.r13: GET .src 13
.r14: GET .src 14
.r14_g0: GE .r14 .C_0
.r14_l9: LE .r14 .C_9
.r14_dg: MUL .r14_g0 .r14_l9
.t14: MUL .r14_dg .T_NUM

-- ============================================
-- DETECTAR PATRONES DOT-ID-COLON
-- ============================================

-- Patrón en posición 0
.m0_d: EQ .t0 .T_DOT
.m0_i: EQ .t1 .T_ID
.m0_c: EQ .t2 .T_COLON
.m0_a: MUL .m0_d .m0_i
.m0: MUL .m0_a .m0_c

-- Patrón en posición 5 (después de newline)
.m5_d: EQ .t5 .T_DOT
.m5_i: EQ .t6 .T_ID
.m5_c: EQ .t7 .T_COLON
.m5_a: MUL .m5_d .m5_i
.m5: MUL .m5_a .m5_c

-- Patrón en posición 10
.m10_d: EQ .t10 .T_DOT
.m10_i: EQ .t11 .T_ID
.m10_c: EQ .t12 .T_COLON
.m10_a: MUL .m10_d .m10_i
.m10: MUL .m10_a .m10_c

-- Total de nodos encontrados
.nodes_a: ADD .m0 .m5
.nodes: ADD .nodes_a .m10

-- ============================================
-- OUTPUT
-- ============================================

.hdr: "Gen0.2 - Autonomia Total\n"
.p0: PRT .hdr 25

.ms: "Bytes: "
.p1: PRT .ms 7
.n1: ITS .len .num
.p2: PRT .num .n1
.p3: PRT "\n" 1

.mt: "Types[0-4]: "
.p4: PRT .mt 12
.n2: ITS .t0 .num
.p5: PRT .num .n2
.p6: PRT " " 1
.n3: ITS .t1 .num
.p7: PRT .num .n3
.p8: PRT " " 1
.n4: ITS .t2 .num
.p9: PRT .num .n4
.p10: PRT " " 1
.n5: ITS .t3 .num
.p11: PRT .num .n5
.p12: PRT " " 1
.n6: ITS .t4 .num
.p13: PRT .num .n6
.p14: PRT "\n" 1

.mt2: "Types[5-9]: "
.p15: PRT .mt2 12
.n7: ITS .t5 .num
.p16: PRT .num .n7
.p17: PRT " " 1
.n8: ITS .t6 .num
.p18: PRT .num .n8
.p19: PRT " " 1
.n9: ITS .t7 .num
.p20: PRT .num .n9
.p21: PRT " " 1
.n10: ITS .t8 .num
.p22: PRT .num .n10
.p23: PRT " " 1
.n11: ITS .t9 .num
.p24: PRT .num .n11
.p25: PRT "\n" 1

.mn: "Nodes: "
.p26: PRT .mn 7
.n12: ITS .nodes .num
.p27: PRT .num .n12
.p28: PRT "\n" 1

.mm: "Matches: pos0="
.p29: PRT .mm 14
.n13: ITS .m0 .num
.p30: PRT .num .n13
.p31: PRT " pos5=" 6
.n14: ITS .m5 .num
.p32: PRT .num .n14
.p33: PRT " pos10=" 7
.n15: ITS .m10 .num
.p34: PRT .num .n15
.p35: PRT "\n" 1

-- ============================================
-- CLEANUP
-- ============================================

.f1: FRE .src
.f2: FRE .num

!
