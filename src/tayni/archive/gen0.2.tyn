-- Byte 6
.r6: GET .src 6
.r6_dot: EQ .r6 .C_DOT
.r6_col: EQ .r6 .C_COLON
.r6_ga: GE .r6 .C_a
.r6_la: LE .r6 .C_z
.r6_lo: MUL .r6_ga .r6_la
.r6_gA: GE .r6 .C_A
.r6_lA: LE .r6 .C_Z
.r6_up: MUL .r6_gA .r6_lA
.r6_al: ADD .r6_lo .r6_up
.r6_g0: GE .r6 .C_0
.r6_l9: LE .r6 .C_9
.r6_dg: MUL .r6_g0 .r6_l9
.t6_a: MUL .r6_dot .T_DOT
.t6_b: MUL .r6_col .T_COLON
.t6_c: MUL .r6_al .T_ID
.t6_d: MUL .r6_dg .T_NUM
.t6_e: ADD .t6_a .t6_b
.t6_f: ADD .t6_e .t6_c
.t6: ADD .t6_f .t6_d

-- Byte 7
.r7: GET .src 7
.r7_dot: EQ .r7 .C_DOT
.r7_col: EQ .r7 .C_COLON
.r7_ga: GE .r7 .C_a
.r7_la: LE .r7 .C_z
.r7_lo: MUL .r7_ga .r7_la
.r7_gA: GE .r7 .C_A
.r7_lA: LE .r7 .C_Z
.r7_up: MUL .r7_gA .r7_lA
.r7_al: ADD .r7_lo .r7_up
.r7_g0: GE .r7 .C_0
.r7_l9: LE .r7 .C_9
.r7_dg: MUL .r7_g0 .r7_l9
.t7_a: MUL .r7_dot .T_DOT
.t7_b: MUL .r7_col .T_COLON
.t7_c: MUL .r7_al .T_ID
.t7_d: MUL .r7_dg .T_NUM
.t7_e: ADD .t7_a .t7_b
.t7_f: ADD .t7_e .t7_c
.t7: ADD .t7_f .t7_d

-- Byte 8
.r8: GET .src 8
.r8_dot: EQ .r8 .C_DOT
.r8_col: EQ .r8 .C_COLON
.r8_ga: GE .r8 .C_a
.r8_la: LE .r8 .C_z
.r8_lo: MUL .r8_ga .r8_la
.r8_gA: GE .r8 .C_A
.r8_lA: LE .r8 .C_Z
.r8_up: MUL .r8_gA .r8_lA
.r8_al: ADD .r8_lo .r8_up
.r8_g0: GE .r8 .C_0
.r8_l9: LE .r8 .C_9
.r8_dg: MUL .r8_g0 .r8_l9
.t8_a: MUL .r8_dot .T_DOT
