# Add this entry to lib/linguist/languages.yml (alphabetically under 'N')
# After getting 200+ repositories using .nela files

NELAIA:
  type: programming
  color: "#4A90D9"
  extensions:
    - ".nela"
  tm_scope: source.nelaia
  ace_mode: text
  codemirror_mode: null
  codemirror_mime_type: null
  wrap: false
  aliases:
    - nelaia
  interpreters: []
  filenames: []
  group: null
