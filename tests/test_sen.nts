-- NELAIA Test: SEN - Sistema de Ecosistema (IA-first)
-- Tests capability discovery and ecosystem operations

-- IA discovers capabilities for JSON processing
.json_caps: DISCOVER "json processing"

-- IA gets info about a capability (Claude's contracts)
.json_info: CAPABILITY_INFO "json"

-- IA checks cost (Mistral's efficiency)
.json_cost: CAPABILITY_COST "json"

-- IA checks regional availability (Qwen's regionalization)
.available: CAPABILITY_AVAILABLE "json" "global"

-- IA gets version
.version: CAPABILITY_VERSION "json"

-- IA gets dependencies
.deps: CAPABILITY_DEPS "json"

-- Print result
.msg: "SEN test: OK\n"
.len: 13
.out: PRT .msg .len
