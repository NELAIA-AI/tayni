-- Parser Test v0.2 - Token format: [type, start, len, 0] (4 bytes)

.input: ".msg: 42"
.len: 8
.zero: 0

.tokens: FSM .input .len
.tptr: ADD .tokens .zero

.cnt: GET .tptr 0

-- Token 0: DOT - offset 8
.t0: ADD .tptr 8
.t0_type: GET .t0 0
.t0_start: GET .t0 1
.t0_len: GET .t0 2

-- Token 1: ID "msg" - offset 12
.t1: ADD .tptr 12
.t1_type: GET .t1 0
.t1_start: GET .t1 1
.t1_len: GET .t1 2

-- Token 2: COLON - offset 16
.t2: ADD .tptr 16
.t2_type: GET .t2 0
.t2_start: GET .t2 1
.t2_len: GET .t2 2

-- Token 3: NUM "42" - offset 20
.t3: ADD .tptr 20
.t3_type: GET .t3 0
.t3_start: GET .t3 1
.t3_len: GET .t3 2

-- Output
.msg1: "Parser v0.2 - 4-byte tokens\n"
.out1: PRT .msg1 28

.msg2: "Input: .msg: 42\n"
.out2: PRT .msg2 16

.msg3: "Tokens: "
.out3: PRT .msg3 8
.cnt_d: ADD .cnt 48
.cbuf: ALC 4
.pc: PUT .cbuf 0 .cnt_d
.pcn: PUT .cbuf 1 10
.out3b: PRT .cbuf 2

.buf: ALC 32

-- T0
.m0: "T0: ty="
.o0: PRT .m0 7
.d0t: ADD .t0_type 48
.p0t: PUT .buf 0 .d0t
.p0s1: PUT .buf 1 32
.o0a: PRT .buf 2
.m0s: "st="
.o0b: PRT .m0s 3
.d0s: ADD .t0_start 48
.p0s: PUT .buf 0 .d0s
.o0c: PRT .buf 2
.m0l: "ln="
.o0d: PRT .m0l 3
.d0l: ADD .t0_len 48
.p0l: PUT .buf 0 .d0l
.p0n: PUT .buf 1 10
.o0e: PRT .buf 2

-- T1
.m1: "T1: ty="
.o1: PRT .m1 7
.d1t: ADD .t1_type 48
.p1t: PUT .buf 0 .d1t
.o1a: PRT .buf 2
.m1s: "st="
.o1b: PRT .m1s 3
.d1s: ADD .t1_start 48
.p1s: PUT .buf 0 .d1s
.o1c: PRT .buf 2
.m1l: "ln="
.o1d: PRT .m1l 3
.d1l: ADD .t1_len 48
.p1l: PUT .buf 0 .d1l
.o1e: PRT .buf 2

-- T2
.m2: "T2: ty="
.o2: PRT .m2 7
.d2t: ADD .t2_type 48
.p2t: PUT .buf 0 .d2t
.o2a: PRT .buf 2
.m2s: "st="
.o2b: PRT .m2s 3
.d2s: ADD .t2_start 48
.p2s: PUT .buf 0 .d2s
.o2c: PRT .buf 2
.m2l: "ln="
.o2d: PRT .m2l 3
.d2l: ADD .t2_len 48
.p2l: PUT .buf 0 .d2l
.o2e: PRT .buf 2

-- T3
.m3: "T3: ty="
.o3: PRT .m3 7
.d3t: ADD .t3_type 48
.p3t: PUT .buf 0 .d3t
.o3a: PRT .buf 2
.m3s: "st="
.o3b: PRT .m3s 3
.d3s: ADD .t3_start 48
.p3s: PUT .buf 0 .d3s
.o3c: PRT .buf 2
.m3l: "ln="
.o3d: PRT .m3l 3
.d3l: ADD .t3_len 48
.p3l: PUT .buf 0 .d3l
.o3e: PRT .buf 2

.exp: "Expected: T1 ln=3 (msg), T3 ln=2 (42)\n"
.oexp: PRT .exp 38

.done: "Done!\n"
.od: PRT .done 6

.result: ADD .out1 .out2 .out3 .out3b .o0 .o0a .o0b .o0c .o0d .o0e .o1 .o1a .o1b .o1c .o1d .o1e .o2 .o2a .o2b .o2c .o2d .o2e .o3 .o3a .o3b .o3c .o3d .o3e .oexp .od
