-- NELAIA Self-Hosting Test: String Operations
-- Tests CAT, CHR, ITS, SBS

.s1: "Hello "
.s2: "NELAIA"
.buf: ALC 64

-- Concatenate strings
.cat: CAT .buf .s1 .s2

-- Get char at index 0 of s1 (should be 'H' = 72)
.c: CHR .s1 0

-- Int to string
.num: 42
.numbuf: ALC 16
.len: ITS .num .numbuf

-- Substring: get "ELA" from "NELAIA" (start=1, len=3)
.subbuf: ALC 16
.sub: SBS .subbuf .s2 1 3

-- Print results
.out1: PRT .buf .cat
.nl: "\n"
.out2: PRT .nl 1
.out3: PRT .subbuf 3
.out4: PRT .nl 1
!
