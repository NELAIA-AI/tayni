// Example 27: Testing Framework
// Demonstrates TAYNI's built-in testing capabilities

// Test attribute marks a function as a test
#[test]
fn test_addition() {
    assert_eq(2 + 2, 4);
    assert_eq(0 + 0, 0);
    assert_eq(-1 + 1, 0);
}

#[test]
fn test_multiplication() {
    assert_eq(3 * 4, 12);
    assert_eq(0 * 100, 0);
    assert_eq(-2 * 3, -6);
}

// Test with custom message
#[test]
fn test_with_message() {
    let result = factorial(5);
    assert_eq(result, 120, "factorial(5) should be 120");
}

// Test that should panic
#[test]
#[should_panic]
fn test_division_by_zero() {
    let _ = 1 / 0;
}

#[test]
#[should_panic(expected = "index out of bounds")]
fn test_array_bounds() {
    let arr = [1, 2, 3];
    let _ = arr[10];
}

// Ignored test (skip during normal runs)
#[test]
#[ignore]
fn test_slow_operation() {
    // This test takes too long for CI
    for i in 0..1000000 {
        let _ = factorial(20);
    }
}

// Test with setup and teardown
#[test]
fn test_with_fixture() {
    // Setup
    let db = TestDatabase::new();
    db.insert("key1", "value1");
    
    // Test
    assert_eq(db.get("key1"), Option::Some("value1"));
    assert_eq(db.get("key2"), Option::None);
    
    // Teardown (automatic with RAII)
}

// Parameterized tests
#[test_case(0, 1)]
#[test_case(1, 1)]
#[test_case(5, 120)]
#[test_case(10, 3628800)]
fn test_factorial_cases(input: i32, expected: i32) {
    assert_eq(factorial(input), expected);
}

// Property-based testing
#[property_test]
fn prop_addition_commutative(a: i32, b: i32) {
    assert_eq(a + b, b + a);
}

#[property_test]
fn prop_addition_associative(a: i32, b: i32, c: i32) {
    assert_eq((a + b) + c, a + (b + c));
}

// Benchmark test
#[bench]
fn bench_factorial() -> BenchResult {
    bench(|| {
        factorial(20)
    })
}

#[bench]
fn bench_fibonacci() -> BenchResult {
    bench(|| {
        fibonacci(30)
    })
}

// Test module organization
mod math_tests {
    #[test]
    fn test_sqrt() {
        assert_approx_eq(sqrt(4.0), 2.0, 0.0001);
        assert_approx_eq(sqrt(2.0), 1.4142, 0.0001);
    }
    
    #[test]
    fn test_pow() {
        assert_eq(pow(2, 10), 1024);
        assert_eq(pow(3, 4), 81);
    }
}

mod string_tests {
    #[test]
    fn test_concat() {
        assert_eq("hello" + " " + "world", "hello world");
    }
    
    #[test]
    fn test_split() {
        let parts = "a,b,c".split(",");
        assert_eq(parts.len(), 3);
        assert_eq(parts[0], "a");
    }
}

// Helper functions for tests
fn factorial(n: i32) -> i32 {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fn fibonacci(n: i32) -> i32 {
    if n <= 1 { n } else { fibonacci(n - 1) + fibonacci(n - 2) }
}

fn sqrt(x: f64) -> f64 {
    x.sqrt()
}

fn pow(base: i32, exp: i32) -> i32 {
    if exp == 0 { 1 }
    else if exp == 1 { base }
    else { base * pow(base, exp - 1) }
}

// Test database fixture
struct TestDatabase {
    data: Map<str, str>
}

impl TestDatabase {
    fn new() -> Self {
        TestDatabase { data: Map::new() }
    }
    
    fn insert(mut self, key: str, value: str) {
        self.data.insert(key, value);
    }
    
    fn get(self, key: str) -> Option<str> {
        self.data.get(key)
    }
}

// Assertion helpers
fn assert_eq<T: Eq + Display>(actual: T, expected: T) {
    if actual != expected {
        panic("Assertion failed: " + actual.display() + " != " + expected.display());
    }
}

fn assert_eq<T: Eq + Display>(actual: T, expected: T, msg: str) {
    if actual != expected {
        panic(msg + ": " + actual.display() + " != " + expected.display());
    }
}

fn assert_approx_eq(actual: f64, expected: f64, epsilon: f64) {
    if (actual - expected).abs() > epsilon {
        panic("Assertion failed: " + actual.to_string() + " !≈ " + expected.to_string());
    }
}

fn assert(condition: bool) {
    if !condition {
        panic("Assertion failed");
    }
}

fn assert(condition: bool, msg: str) {
    if !condition {
        panic(msg);
    }
}

// Main entry point (not run during tests)
fn main() {
    print("Run with 'tayni test' to execute tests");
    print("Run with 'tayni bench' to execute benchmarks");
}
