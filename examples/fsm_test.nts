-- Test FSM v3 - Token grouping
-- Groups consecutive chars of same type

.input: ".msg: 42\n.out: PRT"
.len: 18
.zero: 0

.tokens: FSM .input .len
.tptr: ADD .tokens .zero

-- Read token count
.cnt: GET .tptr 0

-- Read first 6 tokens
.t0_off: ADD .tptr 8
.t0_type: GET .t0_off 0

.t1_off: ADD .tptr 16
.t1_type: GET .t1_off 0

.t2_off: ADD .tptr 24
.t2_type: GET .t2_off 0

.t3_off: ADD .tptr 32
.t3_type: GET .t3_off 0

.t4_off: ADD .tptr 40
.t4_type: GET .t4_off 0

.t5_off: ADD .tptr 48
.t5_type: GET .t5_off 0

-- Output
.msg1: "FSM v3 - Token Grouping\n"
.out1: PRT .msg1 24

.msg2: "Input: .msg: 42\\n.out: PRT\n"
.out2: PRT .msg2 27

.msg3: "Token count: "
.out3: PRT .msg3 13
.cnt_d: ADD .cnt 48
.cbuf: ALC 4
.pc: PUT .cbuf 0 .cnt_d
.pcn: PUT .cbuf 1 10
.out3b: PRT .cbuf 2

.msg4: "Token types: "
.out4: PRT .msg4 13

.buf: ALC 16
.d0: ADD .t0_type 48
.p0: PUT .buf 0 .d0
.sp0: PUT .buf 1 32
.d1: ADD .t1_type 48
.p1: PUT .buf 2 .d1
.sp1: PUT .buf 3 32
.d2: ADD .t2_type 48
.p2: PUT .buf 4 .d2
.sp2: PUT .buf 5 32
.d3: ADD .t3_type 48
.p3: PUT .buf 6 .d3
.sp3: PUT .buf 7 32
.d4: ADD .t4_type 48
.p4: PUT .buf 8 .d4
.sp4: PUT .buf 9 32
.d5: ADD .t5_type 48
.p5: PUT .buf 10 .d5
.pnl: PUT .buf 11 10
.out5: PRT .buf 12

.msg6: "Expected: 1(.) 3(msg) 2(:) 4(42) 6(NL) 1(.)\n"
.out6: PRT .msg6 44

.done: "FSM v3 works!\n"
.out7: PRT .done 14

.result: ADD .out1 .out2 .out3 .out3b .out4 .out5 .out6 .out7
