-- Test FSM (Finite State Machine) - Emergent tokenizer
-- Tokenizes input into structured tokens

.input: ".msg: \"Hello\"\n.out: PRT"
.len: 24

-- FSM tokenizes the input
-- Returns: pointer to token array
-- Header: [count:i64]
-- Each token: [type:i8, pad:i8, start:i32, len:i16]
.tokens: FSM .input .len

-- Read token count from header
.zero: 0
.toks_ptr: ADD .tokens .zero
.tok_count: GET .toks_ptr 0

-- Output
.msg1: "FSM Tokenizer Test\n"
.out1: PRT .msg1 19

.msg2: "Tokens found: "
.out2: PRT .msg2 14

.count_digit: ADD .tok_count 48
.cbuf: ALC 4
.put_c: PUT .cbuf 0 .count_digit
.put_nl: PUT .cbuf 1 10
.out3: PRT .cbuf 2

-- Read first token type (at offset 8)
.tok0_off: ADD .tokens 8
.tok0_type: GET .tok0_off 0

.msg3: "First token type: "
.out4: PRT .msg3 18
.t0_digit: ADD .tok0_type 48
.tbuf: ALC 4
.put_t: PUT .tbuf 0 .t0_digit
.put_nl2: PUT .tbuf 1 10
.out5: PRT .tbuf 2

.done: "FSM works!\n"
.out6: PRT .done 11

.result: ADD .out1 .out2 .out3 .out4 .out5 .out6
