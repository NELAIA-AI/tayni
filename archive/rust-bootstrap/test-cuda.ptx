.visible .entry TAYNI_kernel(
    .param .u64 param_data,
    .param .u32 param_n
)
{
    .reg .pred %p<4>;
    .reg .b32 %r<16>;
    .reg .b64 %rd<8>;
    .reg .f32 %f<8>;

    // Get global thread ID
    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;  // global_id = blockIdx * blockDim + threadIdx

    // Load parameters
    ld.param.u64 %rd0, [param_data];
    ld.param.u32 %r4, [param_n];

    // Bounds check
    setp.ge.s32 %p0, %r3, %r4;
    @%p0 bra $L_exit;

$L_exit:
    ret;
}
