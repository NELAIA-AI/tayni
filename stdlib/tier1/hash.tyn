-- Output: 16-byte hash in .out buffer

.hash_md5: FUN .data .len .out
  -- 4 rounds of 16 operations each
  -- NOT RECOMMENDED for security
  .done: 0
!FUN

-- ============================================================
-- HASH.HMAC_SHA256: HMAC using SHA-256
-- ============================================================
-- Input: .key, .key_len, .data, .data_len
-- Output: 32-byte MAC in .out buffer
--
-- HMAC(K, m) = H((K' ⊕ opad) || H((K' ⊕ ipad) || m))

.hash_hmac_sha256: FUN .key .key_len .data .data_len .out
  -- If key > 64 bytes, hash it first
  -- Pad key to 64 bytes
  
  .ipad: ALC 64  -- 0x36 repeated
  .opad: ALC 64  -- 0x5c repeated
  
  -- XOR key with ipad
  -- Concatenate with message
  -- Hash inner
  
  -- XOR key with opad
  -- Concatenate with inner hash
  -- Hash outer
  
  .done: 0
!FUN

-- ============================================================
-- HASH.BCRYPT: Hash password with bcrypt
-- ============================================================
-- Input: .password, .pass_len, .cost (work factor 4-31)
-- Output: 60-byte bcrypt hash string

.hash_bcrypt: FUN .password .pass_len .cost
  .out: ALC 60
  -- Generate 16-byte salt
  -- Expensive key setup (2^cost iterations)
  -- Encrypt magic string 64 times
  -- Format: $2b$cost$salt+hash
  .done: 0
!FUN

-- ============================================================
-- HASH.BCRYPT_VERIFY: Verify bcrypt hash
-- ============================================================
-- Input: .password, .pass_len, .hash, .hash_len
-- Output: 1 if match, 0 if not

.hash_bcrypt_verify: FUN .password .pass_len .hash .hash_len
  -- Extract cost and salt from hash
  -- Recompute bcrypt with same parameters
  -- Constant-time comparison
  .result: 0
!FUN

-- ============================================================
-- HASH.ARGON2ID: Hash password with Argon2id
-- ============================================================
-- Input: .password, .pass_len, .salt, .salt_len
-- Output: 32-byte hash

.hash_argon2id: FUN .password .pass_len .salt .salt_len
  .out: ALC 32
  -- Memory-hard function
  -- Resistant to GPU/ASIC attacks
  .done: 0
!FUN

-- ============================================================
-- UTILITY: Constant-time comparison
-- ============================================================
-- Prevents timing attacks

.hash_compare: FUN .a .b .len
  -- XOR all bytes, accumulate differences
  -- Return 1 only if all zeros
  .result: 0
!FUN

-- ============================================================
-- USAGE EXAMPLES (AI Reference)
-- ============================================================
--
-- Hash a message:
--   .msg: "Hello, World!"
--   .digest: ALC 32
--   .ok: HASH.SHA256 .msg 13 .digest
--
-- HMAC for API authentication:
--   .secret: "my-api-key"
--   .payload: "{\"user\":\"alice\"}"
--   .mac: ALC 32
--   .ok: HASH.HMAC_SHA256 .secret 10 .payload 17 .mac
--
-- Password hashing:
--   .pwd: "user-password"
--   .hash: HASH.BCRYPT .pwd 13 12
--   -- Store .hash in database
--
-- Password verification:
--   .pwd: "user-password"
--   .stored: "$2b$12$..."
--   .valid: HASH.BCRYPT_VERIFY .pwd 13 .stored 60
