-- ============================================================
-- HASH.SHA256: Compute SHA-256 hash
-- ============================================================
-- Input: .data (pointer), .len (length in bytes)
-- Output: 32-byte hash in .out buffer
--
-- Example:
--   .msg: "hello"
--   .hash: ALC 32
--   .ok: HASH.SHA256 .msg 5 .hash

.hash_sha256: FUN .data .len .out
  -- Initialize hash state
  .h0: ADD .sha256_h0_init 0
  .h1: ADD .sha256_h1_init 0
  .h2: ADD .sha256_h2_init 0
  .h3: ADD .sha256_h3_init 0
  .h4: ADD .sha256_h4_init 0
  .h5: ADD .sha256_h5_init 0
  .h6: ADD .sha256_h6_init 0
  .h7: ADD .sha256_h7_init 0
  
  -- Message schedule array (64 words)
  .w: ALC 256
  
  -- Process each 512-bit (64-byte) block
  -- For AI-native: assume single block for now (< 56 bytes)
  
  -- Padding: append 1 bit, zeros, then length
  .padded: ALC 64
  -- Copy data to padded buffer
  -- Add 0x80 byte
  -- Add length in bits (big-endian) at end
  
  -- Message schedule expansion (rounds 16-63)
  -- w[i] = σ1(w[i-2]) + w[i-7] + σ0(w[i-15]) + w[i-16]
  
  -- Compression function (64 rounds)
  -- Each round: T1 = h + Σ1(e) + Ch(e,f,g) + K[i] + W[i]
  --             T2 = Σ0(a) + Maj(a,b,c)
  
  -- Final hash = initial + compressed
  -- Write to output buffer (big-endian)
  .done: 0
!FUN

-- ============================================================
-- HASH.SHA512: Compute SHA-512 hash
-- ============================================================
-- Input: .data (pointer), .len (length in bytes)
-- Output: 64-byte hash in .out buffer

.hash_sha512: FUN .data .len .out
  -- Similar to SHA-256 but with 64-bit words
  -- 80 rounds instead of 64
  .done: 0
!FUN

-- ============================================================
-- HASH.MD5: Compute MD5 hash (legacy, not secure)
